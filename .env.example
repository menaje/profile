# Public site origin precedence:
# 1. SITE_URL
# 2. PUBLIC_SITE_URL
# 3. fallback in astro.config.mjs -> https://menaje.github.io
#
# Keep these values host-only. The GitHub Pages base path `/profile/`
# is configured separately in `astro.config.mjs`.
SITE_URL=https://menaje.github.io
PUBLIC_SITE_URL=https://menaje.github.io

# Optional Formspree form ID used by `src/pages/contact.astro`.
PUBLIC_FORMSPREE_ID=

# Optional repo-scoped GitHub token used by the blog publish CLI.
# Auth precedence:
# 1. BLOG_GITHUB_TOKEN
# 2. GITHUB_TOKEN
# 3. gh auth token
BLOG_GITHUB_TOKEN=

# Optional CI/automation fallback if BLOG_GITHUB_TOKEN is not set.
GITHUB_TOKEN=
