---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { buildBreadcrumbStructuredData } from "../../lib/structured-data";
import { getFallbackSiteUrl, withBase } from "../../lib/site";

type ProjectEntry = CollectionEntry<"case-studies">;
type ProjectDomain = ProjectEntry["data"]["domain"];

const allProjects = await getCollection("case-studies", (entry: ProjectEntry) => !entry.data.draft);

const projects = allProjects.sort((a: ProjectEntry, b: ProjectEntry) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.period.start.localeCompare(a.data.period.start);
});
const pageTitle = "프로젝트";
const pageDescription =
  "건설 현장의 실제 문제를 시스템으로 번역한 케이스 스터디와 AI/IT 프로젝트를 소개합니다.";
const site = Astro.site ?? getFallbackSiteUrl();
const structuredData = buildBreadcrumbStructuredData({
  site,
  items: [
    { name: "홈", path: "/" },
    { name: "프로젝트", path: "/projects/" },
  ],
});

function allDomains(entry: ProjectEntry): ProjectDomain[] {
  return [entry.data.domain, ...entry.data.extraDomains];
}

function domainLabel(domain: ProjectDomain): string {
  return domain === "construction-cm" ? "건설사업관리" : "AI/IT";
}

function domainBadgeClass(domain: ProjectDomain): string {
  return domain === "construction-cm"
    ? "site-badge site-badge--domain-construction"
    : "site-badge site-badge--domain-ai";
}

function domainCardClass(domain: ProjectDomain): string {
  return domain === "construction-cm"
    ? "site-projects__item--construction"
    : "site-projects__item--ai";
}

function formatPeriod(period: { start: string; end?: string }): string {
  return period.end ? `${period.start} ~ ${period.end}` : `${period.start} ~ 진행 중`;
}

function filterLabel(domain: ProjectDomain | "all"): string {
  switch (domain) {
    case "construction-cm":
      return "건설사업관리";
    case "ai-it":
      return "AI/IT";
    default:
      return "전체";
  }
}
---

<BaseLayout title={pageTitle} description={pageDescription} structuredData={structuredData}>
  <section class="site-projects">
    <header class="site-projects__hero site-page-hero" data-reveal="slide-up">
      <p class="site-page-hero__eyebrow">Projects</p>
      <h1 class="site-page-hero__title">현장의 문제를 시스템 설계로 바꾼 프로젝트</h1>
      <p class="site-page-hero__lead">
        건설사업관리와 AI/IT 사이를 오가며, 복잡한 운영 맥락을 실제로 작동하는 협업 시스템과 자동화
        흐름으로 풀어낸 사례를 모았습니다.
      </p>
      <p class="site-page-hero__meta">
        공개된 케이스 스터디 {projects.length}건
      </p>
    </header>

    {
      projects.length > 0 ? (
        <>
          <div class="site-projects__controls-bar" data-reveal="slide-up">
            <div class="site-projects__segment" role="group" aria-label="도메인 필터">
              {(["all", "construction-cm", "ai-it"] as const).map((filter) => (
                <button
                  type="button"
                  class="site-projects__filter"
                  data-project-filter={filter}
                  data-filter-label={filterLabel(filter)}
                  aria-pressed={filter === "all" ? "true" : "false"}
                >
                  {filterLabel(filter)}
                </button>
              ))}
            </div>
            <p class="site-projects__filter-summary" data-filter-summary aria-live="polite">
              전체 · {projects.length}개 프로젝트
            </p>
          </div>

          <h2 class="site-projects__sr-only">프로젝트 목록</h2>
          <div class="site-projects__grid stagger-children" data-reveal="stagger-children">
            {projects.map((entry: ProjectEntry) => (
              <article
                class:list={[
                  "site-projects__item",
                  "site-card",
                  "site-card--interactive",
                  domainCardClass(entry.data.domain),
                ]}
                data-project-card
                data-domains={allDomains(entry).join(",")}
              >
                <div class="site-projects__item-head">
                  <div class="site-projects__item-badges">
                    {allDomains(entry).map((d) => (
                      <span class={domainBadgeClass(d)}>{domainLabel(d)}</span>
                    ))}
                    {!entry.data.period.end && (
                      <span class="site-badge site-badge--state site-projects__state-badge site-projects__state-badge--ongoing">
                        진행 중
                      </span>
                    )}
                  </div>
                  <p class="site-projects__item-kicker">
                    {entry.data.client} · {formatPeriod(entry.data.period)}
                  </p>
                </div>

                <div class="site-projects__item-body">
                  <h3 class="site-projects__item-title">
                    <a href={withBase(`/projects/${entry.id}/`)}>{entry.data.title}</a>
                  </h3>
                  <p class="site-projects__item-description">{entry.data.description}</p>
                </div>

                <dl class="site-projects__item-meta site-metadata-block">
                  <div class="site-metadata-block__item">
                    <dt>Role</dt>
                    <dd>{entry.data.role}</dd>
                  </div>
                  <div class="site-metadata-block__item">
                    <dt>Period</dt>
                    <dd>{formatPeriod(entry.data.period)}</dd>
                  </div>
                </dl>

                {entry.data.tags.length > 0 && (
                  <ul class="site-projects__tags" role="list">
                    {entry.data.tags.map((tag: string) => (
                      <li class="site-projects__tag">{tag}</li>
                    ))}
                  </ul>
                )}

                <div class="site-projects__item-footer">
                  <a
                    href={withBase(`/projects/${entry.id}/`)}
                    class="site-projects__cta site-button site-button--ghost site-button--quiet"
                  >
                    <span>자세히 보기</span>
                    <span class="site-projects__cta-icon" aria-hidden="true">
                      →
                    </span>
                  </a>
                </div>
              </article>
            ))}
          </div>

          <article
            class="site-projects__no-results site-card"
            data-no-results
            role="status"
            aria-live="polite"
            hidden
          >
            <div class="site-projects__placeholder-copy">
              <h2 class="site-projects__placeholder-title">
                이 필터에 맞는 프로젝트가 아직 없습니다.
              </h2>
              <p class="site-projects__placeholder-text">
                전체 보기로 돌아가거나 다른 도메인을 선택해 보세요.
              </p>
            </div>
            <button type="button" class="site-button site-button--primary" data-filter-reset>
              전체 보기
            </button>
          </article>
        </>
      ) : (
        <article class="site-projects__empty site-card" data-reveal="slide-up">
          <div class="site-projects__placeholder-copy">
            <h2 class="site-projects__placeholder-title">아직 공개된 프로젝트가 없습니다.</h2>
            <p class="site-projects__placeholder-text">
              프로젝트 데이터가 준비되면 이 페이지에 공개할 예정입니다.
            </p>
          </div>
        </article>
      )
    }
  </section>
</BaseLayout>

<script>
  function initProjectFilters() {
    const buttons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-project-filter]"),
    );
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-project-card]"));
    const summary = document.querySelector<HTMLElement>("[data-filter-summary]");
    const noResults = document.querySelector<HTMLElement>("[data-no-results]");
    const resetButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-filter-reset]"),
    );

    function applyFilter(nextFilter: string) {
      let visibleCount = 0;

      buttons.forEach((button) => {
        const isActive = button.dataset.projectFilter === nextFilter;
        button.setAttribute("aria-pressed", String(isActive));
      });

      cards.forEach((card) => {
        const domains = (card.dataset.domains ?? "").split(",");
        const matches = nextFilter === "all" || domains.includes(nextFilter);
        card.hidden = !matches;
        if (matches) visibleCount += 1;
      });

      const activeButton = buttons.find((button) => button.dataset.projectFilter === nextFilter);
      const label = activeButton?.dataset.filterLabel ?? "전체";

      if (summary) {
        summary.textContent = `${label} · ${visibleCount}개 프로젝트`;
      }

      if (noResults) {
        noResults.hidden = visibleCount > 0;
      }
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        applyFilter(button.dataset.projectFilter ?? "all");
      });
    });

    resetButtons.forEach((button) => {
      button.addEventListener("click", () => {
        applyFilter("all");
        buttons[0]?.focus();
      });
    });

    if (buttons.length > 0) {
      applyFilter("all");
    }
  }

  // View Transitions 네비게이션 시
  document.addEventListener("astro:page-load", initProjectFilters);
  // 초기 로드 폴백
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initProjectFilters);
  } else {
    initProjectFilters();
  }
</script>

<style>
  .site-projects {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
    padding: var(--space-xl) var(--site-gutter) var(--space-2xl);
  }

  .site-projects__hero {
    margin-bottom: var(--space-2xl);
  }

  .site-projects__controls-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .site-projects__segment {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-2xs);
    width: 100%;
    max-width: 30rem;
    padding: var(--space-2xs);
    border: 1px solid var(--site-border-default);
    border-radius: calc(var(--radius-pill) + var(--space-2xs));
    background: var(--site-surface-muted);
  }

  .site-projects__filter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 var(--space-md);
    border: none;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--color-text-secondary);
    font: inherit;
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-projects__filter:hover {
    color: var(--color-primary);
  }

  .site-projects__filter:focus-visible {
    outline: none;
    box-shadow: var(--site-shadow-focus);
  }

  .site-projects__filter[aria-pressed="true"] {
    background: var(--color-primary);
    color: var(--site-on-inverse);
    box-shadow: var(--site-shadow-flat);
  }

  .site-projects__filter-summary {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .site-projects__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-projects__grid {
    display: grid;
    gap: var(--space-xl);
  }

  .site-projects__item {
    --site-projects-card-accent: var(--color-primary);
    position: relative;
    gap: var(--space-lg);
    overflow: hidden;
    background: var(--site-surface-elevated);
  }

  .site-projects__item[hidden] {
    display: none;
  }

  .site-projects__item::before {
    display: none;
  }

  .site-projects__item::after {
    display: none;
  }

  .site-projects__item[data-domain="construction-cm"],
  .site-projects__item--construction {
    --site-projects-card-accent: var(--color-accent);
  }

  .site-projects__item[data-domain="ai-it"],
  .site-projects__item--ai {
    --site-projects-card-accent: var(--color-primary);
  }

  .site-projects__item-head,
  .site-projects__item-body,
  .site-projects__item-footer {
    display: grid;
    gap: var(--space-sm);
  }

  .site-projects__item-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    align-items: center;
  }

  .site-projects__state-badge {
    align-self: flex-start;
  }

  .site-projects__item-kicker {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-projects__item-title {
    margin: 0;
    font-size: clamp(var(--text-xl), 1.1rem + 1vw, var(--text-3xl));
    line-height: var(--line-height-tight);
    color: var(--color-ink);
  }

  .site-projects__item-title a {
    color: inherit;
    text-decoration: none;
  }

  .site-projects__item-title a:hover {
    color: var(--site-projects-card-accent);
  }

  .site-projects__item-description,
  .site-projects__item-role,
  .site-projects__item-note {
    margin: 0;
    line-height: var(--line-height-body);
  }

  .site-projects__item-description {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
  }

  .site-projects__item-role {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .site-projects__item-meta {
    background: var(--site-surface-muted);
  }

  .site-projects__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-projects__tag {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0 var(--space-sm);
    border: 1px solid var(--site-border-default);
    border-radius: var(--radius-pill);
    background: var(--site-surface-muted);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .site-projects__item-footer {
    margin-top: auto;
    padding-top: var(--space-xs);
  }

  .site-projects__cta {
    align-self: flex-start;
    color: var(--color-ink);
    background: var(--site-surface-muted);
  }

  .site-projects__cta-icon {
    font-size: 0.95em;
    line-height: 1;
  }

  .site-projects__placeholder,
  .site-projects__no-results,
  .site-projects__empty {
    align-items: flex-start;
    gap: var(--space-lg);
    padding: clamp(var(--space-lg), 4vw, var(--space-2xl));
    background: var(--site-surface-elevated);
  }

  .site-projects__empty-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border: 1px solid var(--site-border-default);
    border-radius: var(--radius-pill);
    background: var(--site-surface-muted);
    color: var(--color-primary);
  }

  .site-projects__empty-icon svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  .site-projects__placeholder-copy {
    display: grid;
    gap: var(--space-xs);
  }

  .site-projects__placeholder-title {
    margin: 0;
    font-size: clamp(var(--text-xl), 1rem + 1vw, var(--text-2xl));
    line-height: var(--line-height-tight);
    color: var(--color-ink);
  }

  .site-projects__placeholder-text {
    margin: 0;
    max-width: 42rem;
    font-size: var(--text-md);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
  }

  @media (hover: hover) and (pointer: fine) {
    .site-projects__item-footer {
      min-height: 4.85rem;
    }

    .site-projects__item-note,
    .site-projects__cta {
      transition:
        opacity var(--transition-base),
        transform var(--transition-base),
        background var(--transition-fast),
        color var(--transition-fast),
        border-color var(--transition-fast),
        box-shadow var(--transition-fast);
    }

    .site-projects__item-note {
      transform: translateY(0.4rem);
      opacity: 0.8;
    }

    .site-projects__cta {
      opacity: 0;
      transform: translateY(1rem);
      pointer-events: none;
    }

    .site-projects__item:hover .site-projects__item-note,
    .site-projects__item:focus-within .site-projects__item-note {
      transform: translateY(0);
      opacity: 1;
    }

    .site-projects__item:hover .site-projects__cta,
    .site-projects__item:focus-within .site-projects__cta {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
  }

  @media (min-width: 768px) {
    .site-projects {
      padding-top: var(--space-2xl);
    }

    .site-projects__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .site-projects__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-projects__filter {
      transition: none;
    }

    .site-projects__filter[aria-pressed="true"] {
      box-shadow: none;
    }

    .site-projects__item-note,
    .site-projects__cta {
      opacity: 1 !important;
      transform: none !important;
      pointer-events: auto !important;
      transition: none !important;
    }

    .site-projects__item-footer {
      min-height: auto;
    }
  }
</style>
