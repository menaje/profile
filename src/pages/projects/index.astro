---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const allProjects = await getCollection(
  "case-studies",
  (entry: CollectionEntry<"case-studies">) => !entry.data.draft,
);

const projects = allProjects.sort(
  (a: CollectionEntry<"case-studies">, b: CollectionEntry<"case-studies">) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.period.start.localeCompare(a.data.period.start);
  },
);

function domainLabel(domain: string): string {
  return domain === "construction-cm" ? "건설사업관리" : "AI/IT";
}

function formatPeriod(period: { start: string; end?: string }): string {
  return period.end ? `${period.start} ~ ${period.end}` : `${period.start} ~ 진행 중`;
}
---

<BaseLayout
  title="프로젝트"
  description="건설CM과 AI/IT 도메인의 프로젝트를 소개합니다."
>
  <section class="site-projects">
    <div class="site-projects__header">
      <h1 class="site-projects__title">프로젝트</h1>
      <p class="site-projects__description">
        건설 현장의 실제 문제를 기술로 해결한 프로젝트를 소개합니다.
      </p>
    </div>

    {
      projects.length > 0 && (
        <div
          class="site-projects__filters"
          role="group"
          aria-label="도메인 필터"
        >
          <button
            class="site-projects__filter-btn"
            data-filter="all"
            aria-pressed="true"
          >
            전체
          </button>
          <button
            class="site-projects__filter-btn"
            data-filter="construction-cm"
            aria-pressed="false"
          >
            건설사업관리
          </button>
          <button
            class="site-projects__filter-btn"
            data-filter="ai-it"
            aria-pressed="false"
          >
            AI/IT
          </button>
        </div>
      )
    }

    {
      projects.length > 0 ? (
        <>
          <div class="site-projects__grid">
            {projects.map((entry: CollectionEntry<"case-studies">) => (
              <article
                class="site-projects__card surface-card"
                data-domain={entry.data.domain}
              >
                <div class="site-projects__card-head">
                  <span class="pill">{domainLabel(entry.data.domain)}</span>
                  {entry.data.featured && (
                    <span class="status-chip">Featured</span>
                  )}
                </div>
                <h2 class="site-projects__card-title">
                  <a href={`/projects/${entry.id}/`}>{entry.data.title}</a>
                </h2>
                <p class="site-projects__card-desc">{entry.data.description}</p>
                <p class="site-projects__card-role">{entry.data.role}</p>
                <div class="site-projects__card-meta">
                  <span class="site-projects__card-period">
                    {formatPeriod(entry.data.period)}
                  </span>
                </div>
                {entry.data.tags.length > 0 && (
                  <ul class="site-projects__card-tags" role="list">
                    {entry.data.tags.map((tag: string) => (
                      <li class="site-projects__card-tag">{tag}</li>
                    ))}
                  </ul>
                )}
              </article>
            ))}
          </div>
          <p class="site-projects__no-results" hidden>
            해당 도메인의 프로젝트가 없습니다.
          </p>
        </>
      ) : (
        <p class="site-projects__empty">아직 등록된 프로젝트가 없습니다.</p>
      )
    }
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(
    ".site-projects__filter-btn",
  );
  const cards =
    document.querySelectorAll<HTMLElement>(".site-projects__card");
  const noResults = document.querySelector<HTMLElement>(
    ".site-projects__no-results",
  );

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;

      buttons.forEach((b) => b.setAttribute("aria-pressed", "false"));
      btn.setAttribute("aria-pressed", "true");

      let visibleCount = 0;
      cards.forEach((card) => {
        const show = filter === "all" || card.dataset.domain === filter;
        card.hidden = !show;
        if (show) visibleCount++;
      });

      if (noResults) {
        noResults.hidden = visibleCount > 0;
      }
    });
  });
</script>

<style>
  .site-projects {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
    padding: var(--space-xl) var(--site-gutter) var(--space-2xl);
  }

  .site-projects__header {
    margin-bottom: var(--space-xl);
  }

  .site-projects__title {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-xs);
    color: var(--color-ink);
  }

  .site-projects__description {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ── Filters ── */
  .site-projects__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-xl);
  }

  .site-projects__filter-btn {
    padding: var(--space-xs) var(--space-md);
    font-size: var(--text-sm);
    font-family: inherit;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition:
      background var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .site-projects__filter-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .site-projects__filter-btn:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .site-projects__filter-btn[aria-pressed="true"] {
    background: var(--color-primary);
    color: var(--color-paper);
    border-color: var(--color-primary);
  }

  /* ── Grid ── */
  .site-projects__grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: 1fr;
  }

  /* ── Card ── */
  .site-projects__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .site-projects__card:hover {
    transform: var(--hover-lift);
    box-shadow: var(--hover-shadow);
  }

  .site-projects__card[hidden] {
    display: none;
  }

  .site-projects__card-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
  }

  .site-projects__card-title {
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin: 0;
    line-height: 1.4;
  }

  .site-projects__card-title a {
    color: inherit;
    text-decoration: none;
  }

  .site-projects__card-title a:hover {
    color: var(--color-primary);
  }

  .site-projects__card-desc {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .site-projects__card-role {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .site-projects__card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-top: auto;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-line);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .site-projects__card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-projects__card-tag {
    display: inline-block;
    padding: 2px var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    border-radius: var(--radius-pill);
  }

  /* ── Empty / No Results ── */
  .site-projects__empty,
  .site-projects__no-results {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    padding: var(--space-2xl) 0;
  }

  /* ── Responsive ── */
  @media (min-width: 768px) {
    .site-projects {
      padding-top: var(--space-2xl);
    }

    .site-projects__title {
      font-size: var(--text-4xl);
    }

    .site-projects__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .site-projects__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
