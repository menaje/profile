---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getPublicProfile,
  getAnonymizedOrgName,
  getAnonymizedClient,
} from "../../lib/public-profile";

export async function getStaticPaths() {
  const entries = await getCollection("case-studies");
  return entries
    .filter((e: CollectionEntry<"case-studies">) => !e.data.draft)
    .map((entry: CollectionEntry<"case-studies">) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"case-studies"> };
const { Content } = await render(entry);

const profile = getPublicProfile();
const project = [...profile.projects.core, ...profile.projects.supporting].find(
  (p) => p.id === entry.id,
);

const orgName = project?.organizationId
  ? getAnonymizedOrgName(project.organizationId)
  : "";
const clientName = getAnonymizedClient(entry.id, entry.data.client);

const domainLabel =
  entry.data.domain === "construction-cm" ? "건설사업관리" : "AI/IT";
---

<BaseLayout title={`${entry.data.title} — 프로젝트`} description={entry.data.description}>
  <article class="site-case-study">
    <header class="site-case-study__header site-page-hero">
      <div class="site-case-study__breadcrumb">
        <a href="/projects">프로젝트</a>
        <span aria-hidden="true">/</span>
        <span>{entry.data.title}</span>
      </div>

      <h1 class="site-case-study__title site-page-hero__title">
        {entry.data.title}
      </h1>

      <p class="site-case-study__lead site-page-hero__lead">
        {entry.data.description}
      </p>

      <dl class="site-case-study__meta site-metadata-block">
        <div class="site-metadata-block__item">
          <dt>기간</dt>
          <dd>
            {entry.data.period.start}{entry.data.period.end ? ` ~ ${entry.data.period.end}` : " ~ 진행 중"}
          </dd>
        </div>
        <div class="site-metadata-block__item">
          <dt>역할</dt>
          <dd>{entry.data.role}</dd>
        </div>
        {clientName && (
          <div class="site-metadata-block__item">
            <dt>발주처</dt>
            <dd>{clientName}</dd>
          </div>
        )}
        {orgName && (
          <div class="site-metadata-block__item">
            <dt>소속</dt>
            <dd>{orgName}</dd>
          </div>
        )}
        <div class="site-metadata-block__item">
          <dt>도메인</dt>
          <dd>{domainLabel}</dd>
        </div>
      </dl>

      {entry.data.tags.length > 0 && (
        <ul class="site-case-study__tags" role="list">
          {entry.data.tags.map((tag: string) => (
            <li class="site-case-study__tag site-badge site-badge--primary">
              {tag}
            </li>
          ))}
        </ul>
      )}
    </header>

    <div class="site-case-study__content">
      <Content />
    </div>

    <footer class="site-case-study__footer">
      <a href="/projects" class="site-case-study__back">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m12 19-7-7 7-7"></path>
          <path d="M19 12H5"></path>
        </svg>
        모든 프로젝트 보기
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .site-case-study {
    max-width: var(--site-max-width);
    margin: 0 auto;
    padding: var(--space-2xl) var(--site-gutter);
  }

  /* --- Header --- */
  .site-case-study__header {
    margin-bottom: var(--space-3xl);
  }

  .site-case-study__breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .site-case-study__breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .site-case-study__breadcrumb a:hover {
    text-decoration: underline;
  }

  .site-case-study__meta {
    margin: 0 0 var(--space-lg);
  }

  .site-case-study__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* --- Content (MDX body) --- */
  .site-case-study__content {
    line-height: var(--line-height-body);
    color: var(--color-text);
  }

  .site-case-study__content :global(h2) {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-ink);
    margin: var(--space-3xl) 0 var(--space-md);
    padding-bottom: var(--space-xs);
    border-bottom: 2px solid var(--color-accent);
  }

  .site-case-study__content :global(h2:first-child) {
    margin-top: 0;
  }

  .site-case-study__content :global(h3) {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-ink);
    margin: var(--space-2xl) 0 var(--space-sm);
  }

  .site-case-study__content :global(p) {
    margin: 0 0 var(--space-md);
    max-width: 40rem;
  }

  .site-case-study__content :global(ul),
  .site-case-study__content :global(ol) {
    margin: 0 0 var(--space-md);
    padding-left: var(--space-xl);
    max-width: 40rem;
  }

  .site-case-study__content :global(li) {
    margin-bottom: var(--space-xs);
  }

  .site-case-study__content :global(li strong) {
    color: var(--color-ink);
  }

  .site-case-study__content :global(table) {
    width: 100%;
    max-width: 40rem;
    border-collapse: collapse;
    margin: 0 0 var(--space-xl);
    font-size: var(--text-sm);
  }

  .site-case-study__content :global(th) {
    text-align: left;
    padding: var(--space-xs) var(--space-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    border-bottom: 2px solid var(--color-line);
  }

  .site-case-study__content :global(td) {
    padding: var(--space-xs) var(--space-sm);
    border-bottom: 1px solid var(--color-line);
  }

  /* --- Footer --- */
  .site-case-study__footer {
    margin-top: var(--space-4xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-line);
  }

  .site-case-study__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .site-case-study__back:hover {
    color: var(--color-ink);
  }

  /* --- Mobile responsive --- */
  @media (max-width: 640px) {
    .site-case-study {
      padding: var(--space-lg) var(--site-gutter);
    }

    .site-case-study__meta {
      grid-template-columns: 1fr 1fr;
    }

    .site-case-study__content :global(table) {
      font-size: var(--text-xs);
    }

    .site-case-study__content :global(th),
    .site-case-study__content :global(td) {
      padding: var(--space-2xs) var(--space-xs);
    }
  }
</style>
