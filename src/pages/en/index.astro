---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublicProfile } from "../../lib/public-profile";
import { withBase } from "../../lib/site";
import { buildPersonStructuredData, buildWebsiteStructuredData } from "../../lib/structured-data";
import { getFallbackSiteUrl } from "../../lib/site";

const data = getPublicProfile();
const pageTitle = "Seongsik Kim — AI-Native System Architect";
const pageDescription =
  "System architect with 9+ years in Construction CM and AI/IT, translating domain problems into AI collaboration systems.";
const site = Astro.site ?? getFallbackSiteUrl();
const structuredData = [
  buildPersonStructuredData({ site, profile: data.profile, description: pageDescription }),
  buildWebsiteStructuredData({ site, profile: data.profile, description: pageDescription }),
];
const { github, linkedin } = data.profile.contacts;
---

<BaseLayout lang="en" title={pageTitle} description={pageDescription} structuredData={structuredData}>
  <section class="en-hero">
    <div class="en-hero__inner">
      <p class="en-hero__eyebrow">AI-Native System Architect</p>
      <h1 class="en-hero__title">
        Translating domain problems<br />into AI collaboration systems
      </h1>
      <p class="en-hero__lead">
        With {data.careerSummary.totalCareer.label} of combined experience in Construction
        Management and AI/IT, I design systems that bridge real-world domain expertise with
        modern AI capabilities.
      </p>
      <div class="en-hero__actions">
        <a href={withBase("/en/contact/")} class="site-button site-button--primary site-button--glow">
          Get in Touch
        </a>
        <a href={withBase("/en/projects/")} class="site-button site-button--ghost">
          View Projects
        </a>
      </div>
    </div>
  </section>

  <section class="en-proof">
    <div class="en-proof__inner">
      <div class="en-proof__stat">
        <span class="en-proof__value">{data.careerSummary.totalCareer.label}</span>
        <span class="en-proof__label">Total Experience</span>
      </div>
      <div class="en-proof__stat">
        <span class="en-proof__value">{data.careerSummary.constructionCm.label}</span>
        <span class="en-proof__label">Construction CM</span>
      </div>
      <div class="en-proof__stat">
        <span class="en-proof__value">{data.careerSummary.aiIt.label}</span>
        <span class="en-proof__label">AI / IT</span>
      </div>
    </div>
  </section>

  <section class="en-about-brief">
    <div class="en-about-brief__inner">
      <h2>Domain Bridge</h2>
      <p>
        I started in construction project management, where I saw critical knowledge scattered
        across documents and meetings. That experience led me to AI systems — not as a trend,
        but as a structural answer to real operational gaps.
      </p>
      <p>
        Today I design AI-powered collaboration systems that connect domain context with
        automated workflows, turning implicit knowledge into actionable intelligence.
      </p>
      <a href={withBase("/en/about/")} class="site-button site-button--ghost">
        Read Full Story
      </a>
    </div>
  </section>

  <section class="en-cta">
    <div class="en-cta__inner">
      <h2>Want to Work Together?</h2>
      <p>Open to project proposals, collaborations, and new opportunities.</p>
      <div class="en-cta__actions">
        <a href={withBase("/en/contact/")} class="site-button site-button--primary">
          Contact Me
        </a>
      </div>
      <div class="en-cta__social">
        <a href={github.url} target="_blank" rel="noopener noreferrer" class="site-button site-button--ghost site-button--icon" aria-label="GitHub">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href={linkedin.url} target="_blank" rel="noopener noreferrer" class="site-button site-button--ghost site-button--icon" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .en-hero {
    padding: clamp(var(--space-4xl), 12vw, 8rem) var(--site-gutter) var(--space-3xl);
  }

  .en-hero__inner {
    max-width: var(--site-max-width);
    margin: 0 auto;
    display: grid;
    gap: var(--space-lg);
  }

  .en-hero__eyebrow {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .en-hero__title {
    margin: 0;
    font-size: clamp(var(--text-3xl), 5vw, var(--text-6xl));
    line-height: var(--line-height-tight);
    letter-spacing: -0.04em;
  }

  .en-hero__lead {
    max-width: 56ch;
    margin: 0;
    font-size: clamp(var(--text-md), 1rem + 0.5vw, var(--text-lg));
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
  }

  .en-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .en-proof {
    padding: var(--space-2xl) var(--site-gutter);
    border-block: 1px solid var(--site-border-default);
    background: var(--site-surface-muted);
  }

  .en-proof__inner {
    max-width: var(--site-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
    gap: var(--space-xl);
    text-align: center;
  }

  .en-proof__stat {
    display: grid;
    gap: var(--space-2xs);
  }

  .en-proof__value {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-ink);
  }

  .en-proof__label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .en-about-brief {
    padding: var(--space-4xl) var(--site-gutter);
  }

  .en-about-brief__inner {
    max-width: var(--site-max-width);
    margin: 0 auto;
    display: grid;
    gap: var(--space-md);
    max-width: 56ch;
  }

  .en-about-brief__inner h2 {
    font-size: var(--text-2xl);
    margin: 0;
  }

  .en-about-brief__inner p {
    margin: 0;
    font-size: var(--text-md);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
  }

  .en-cta {
    padding: var(--space-4xl) var(--site-gutter);
    border-top: 1px solid var(--site-border-default);
    background: var(--site-surface-muted);
    text-align: center;
  }

  .en-cta__inner {
    max-width: var(--site-max-width);
    margin: 0 auto;
    display: grid;
    gap: var(--space-md);
    justify-items: center;
  }

  .en-cta__inner h2 {
    font-size: var(--text-2xl);
    margin: 0;
  }

  .en-cta__inner > p {
    margin: 0;
    color: var(--color-text-secondary);
  }

  .en-cta__actions {
    display: flex;
    gap: var(--space-sm);
  }

  .en-cta__social {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }
</style>
