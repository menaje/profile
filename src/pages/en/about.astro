---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublicProfile } from "../../lib/public-profile";
import { buildBreadcrumbStructuredData, buildProfilePageStructuredData } from "../../lib/structured-data";
import { getFallbackSiteUrl } from "../../lib/site";

const data = getPublicProfile();
const { careerSummary } = data;
const pageTitle = "About — Seongsik Kim";
const pageDescription =
  "From 9 years in Construction CM to AI System Architect. Career transition narrative and experience timeline.";
const site = Astro.site ?? getFallbackSiteUrl();
const structuredData = [
  buildBreadcrumbStructuredData({
    site,
    items: [
      { name: "Home", path: "/en/" },
      { name: "About", path: "/en/about/" },
    ],
  }),
  buildProfilePageStructuredData({
    site,
    path: "/en/about/",
    profile: data.profile,
    name: pageTitle,
    description: pageDescription,
  }),
];
---

<BaseLayout lang="en" title={pageTitle} description={pageDescription} structuredData={structuredData}>
  <div class="en-page" style="max-width: var(--site-content-max-width); margin: 0 auto;">
    <section class="en-page__hero site-page-hero">
      <p class="site-page-hero__eyebrow">About</p>
      <div class="site-section-header__rule" aria-hidden="true"></div>
      <h1 class="site-page-hero__title">
        An architect finding answers<br />through AI after 9 years of questions
      </h1>
      <p class="site-page-hero__lead">
        I spent {careerSummary.constructionCm.label} in construction project management and
        {careerSummary.aiIt.label} in AI service planning and development. The industries
        changed, but the question binding my career stayed the same.
      </p>
      <ul class="en-page__badges" role="list" aria-label="Career summary">
        <li><span class="site-badge site-badge--neutral">Total {careerSummary.totalCareer.label}</span></li>
        <li><span class="site-badge site-badge--domain-construction">CM {careerSummary.constructionCm.label}</span></li>
        <li><span class="site-badge site-badge--domain-ai">AI/IT {careerSummary.aiIt.label}</span></li>
      </ul>
    </section>

    <section class="en-page__card site-card">
      <span class="en-page__number" aria-hidden="true">01</span>
      <div class="en-page__content">
        <p class="en-page__eyebrow">Problem Awareness</p>
        <h2>Turning repeated field losses into technology questions</h2>
        <p>
          The starting point wasn't a new trend but <strong>recurring operational losses</strong> on
          construction sites. Documents and meetings piled up, but the right context was never
          available at critical moments.
        </p>
        <p>
          Over <strong>{careerSummary.constructionCm.label}</strong> of field work, I became
          convinced this wasn't simple inefficiency — it was a structural problem slowing down
          all knowledge work.
        </p>
      </div>
    </section>

    <blockquote class="en-page__quote">
      <p>
        Why does data accumulate but judgment doesn't?<br />
        Why do projects repeat but experience doesn't carry over?
      </p>
    </blockquote>

    <section class="en-page__card site-card">
      <span class="en-page__number" aria-hidden="true">02</span>
      <div class="en-page__content">
        <p class="en-page__eyebrow">Career Transition</p>
        <h2>Problems drove the technology, automation became the pivot</h2>
        <p>
          The transition wasn't a sudden switch but a series of small automations. Structuring
          qualitative judgments in VE work showed that report quality and speed could improve
          simultaneously. Designing a <strong>document management system spanning 5 sites</strong>
          proved that registration, summarization, and monthly reporting could flow as one.
        </p>
        <p>
          Coming from a non-IT background, the steepest growth came not from learning languages or
          tools, but from the <strong>discipline of defining problems precisely</strong>.
        </p>
      </div>
    </section>

    <section class="en-page__card site-card">
      <span class="en-page__number" aria-hidden="true">03</span>
      <div class="en-page__content">
        <p class="en-page__eyebrow">Future Vision</p>
        <h2>Solving domain complexity with production-grade AI systems</h2>
        <p>
          I want to build systems that <strong>remember context, connect the basis of judgment,
          and earn real user trust</strong> — not simple automation, but intelligent infrastructure
          that transforms how organizations make decisions.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .en-page {
    padding: clamp(var(--space-3xl), 8vw, var(--space-5xl)) var(--site-gutter)
      clamp(var(--space-4xl), 10vw, 6rem);
    display: grid;
    gap: clamp(var(--space-2xl), 6vw, 4.5rem);
  }

  .en-page :where(section, blockquote) {
    margin: 0;
  }

  .en-page__hero {
    margin-bottom: 0;
  }

  .en-page__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .en-page__card {
    position: relative;
    overflow: hidden;
    padding: clamp(var(--space-xl), 4vw, var(--space-2xl));
    background: var(--site-surface-elevated);
  }

  .en-page__number {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-lg);
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: 0.82;
    color: color-mix(in srgb, var(--color-text-muted) 18%, transparent);
    pointer-events: none;
    user-select: none;
  }

  .en-page__content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-md);
    max-width: 38rem;
  }

  .en-page__content h2 {
    margin: 0;
    font-size: clamp(var(--text-xl), 2vw + 1rem, var(--text-3xl));
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .en-page__content p {
    margin: 0;
    font-size: var(--text-md);
    line-height: var(--line-height-body);
    color: var(--color-text);
  }

  .en-page__content strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  .en-page__eyebrow {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .en-page__quote {
    padding: clamp(var(--space-lg), 4vw, 2.5rem);
    border-inline-start: 4px solid var(--color-secondary);
    background: var(--site-surface-muted);
    border-radius: var(--radius-md);
  }

  .en-page__quote p {
    margin: 0;
    font-size: clamp(var(--text-md), 0.85rem + 0.5vw, var(--text-xl));
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-ink);
  }
</style>
