---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublicProfile } from "../../lib/public-profile";
import { buildBreadcrumbStructuredData } from "../../lib/structured-data";
import { getFallbackSiteUrl } from "../../lib/site";

const data = getPublicProfile();
const { github, linkedin } = data.profile.contacts;
const site = Astro.site ?? getFallbackSiteUrl();
const pageTitle = "Contact — Seongsik Kim";
const pageDescription = "Get in touch for project proposals, collaborations, or career discussions.";
const structuredData = buildBreadcrumbStructuredData({
  site,
  items: [
    { name: "Home", path: "/en/" },
    { name: "Contact", path: "/en/contact/" },
  ],
});
---

<BaseLayout lang="en" title={pageTitle} description={pageDescription} structuredData={structuredData}>
  <div class="en-page" style="max-width: var(--site-content-max-width); margin: 0 auto;">
    <section class="en-page__hero site-page-hero">
      <p class="site-page-hero__eyebrow">Contact</p>
      <div class="site-section-header__rule" aria-hidden="true"></div>
      <h1 class="site-page-hero__title">Get in Touch</h1>
      <p class="site-page-hero__lead">
        Open to project proposals, technical collaborations, and career opportunities.
        Feel free to reach out through any channel below.
      </p>
    </section>

    <div class="en-contact__channels">
      <a href={github.url} target="_blank" rel="noopener noreferrer" class="en-contact__card site-card site-card--interactive">
        <div class="en-contact__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </div>
        <h2>GitHub</h2>
        <p>{github.username}</p>
      </a>

      <a href={linkedin.url} target="_blank" rel="noopener noreferrer" class="en-contact__card site-card site-card--interactive">
        <div class="en-contact__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </div>
        <h2>LinkedIn</h2>
        <p>LinkedIn Profile</p>
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .en-page {
    padding: clamp(var(--space-3xl), 8vw, var(--space-5xl)) var(--site-gutter)
      clamp(var(--space-4xl), 10vw, 6rem);
    display: grid;
    gap: var(--space-2xl);
  }

  .en-page__hero {
    margin-bottom: 0;
  }

  .en-contact__channels {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .en-contact__channels {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .en-contact__card {
    text-decoration: none;
    color: inherit;
    text-align: center;
    align-items: center;
    gap: var(--space-sm);
  }

  .en-contact__icon {
    color: var(--color-primary);
  }

  .en-contact__card h2 {
    margin: 0;
    font-size: var(--text-lg);
  }

  .en-contact__card p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    word-break: break-all;
  }
</style>
