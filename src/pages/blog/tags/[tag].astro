---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  getBlogTagDescriptor,
  getBlogTagDescriptors,
  postHasBlogTag,
  type BlogTagDescriptor,
} from "../../../lib/blog-tags";
import { buildBreadcrumbStructuredData } from "../../../lib/structured-data";
import { getFallbackSiteUrl, withBase } from "../../../lib/site";

function formatDate(date: Date): string {
  return date.toLocaleDateString("ko-KR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", (entry: CollectionEntry<"blog">) => {
    return import.meta.env.PROD ? entry.data.draft !== true : true;
  });
  const allTags = getBlogTagDescriptors(allPosts);

  return allTags.map((selectedTag) => ({
    params: { tag: selectedTag.slug },
    props: {
      allTags,
      selectedTag,
      posts: allPosts
        .filter((post: CollectionEntry<"blog">) => postHasBlogTag(post, selectedTag.label))
        .sort(
          (left: CollectionEntry<"blog">, right: CollectionEntry<"blog">) =>
            right.data.publishedDate.getTime() - left.data.publishedDate.getTime(),
        ),
    },
  }));
}

interface Props {
  allTags: BlogTagDescriptor[];
  selectedTag: BlogTagDescriptor;
  posts: CollectionEntry<"blog">[];
}

const { allTags, selectedTag, posts } = Astro.props as Props;
const pageTitle = `#${selectedTag.label} 태그 글`;
const pageDescription =
  posts.length > 0
    ? `${selectedTag.label} 태그가 붙은 ${posts.length}개의 글만 모아 빠르게 둘러볼 수 있습니다.`
    : `${selectedTag.label} 태그와 연결된 글을 준비 중입니다.`;
const pagePath = `/blog/tags/${selectedTag.slug}/`;
const site = Astro.site ?? getFallbackSiteUrl();
const structuredData = buildBreadcrumbStructuredData({
  site,
  items: [
    { name: "홈", path: "/" },
    { name: "블로그", path: "/blog/" },
    { name: selectedTag.label, path: pagePath },
  ],
});
---

<BaseLayout title={pageTitle} description={pageDescription} structuredData={structuredData}>
  <section class="site-blog-tag-page">
    <div class="site-page-hero site-blog-tag-page__hero" data-reveal="slide-up">
      <a
        href={withBase("/blog/")}
        class="site-blog-tag-page__back site-button site-button--ghost site-button--quiet"
      >
        <span aria-hidden="true">←</span>
        <span>블로그 목록</span>
      </a>

      <p class="site-page-hero__eyebrow">Tag Archive</p>
      <h1 class="site-page-hero__title">#{selectedTag.label}</h1>
      <p class="site-page-hero__lead">
        같은 태그로 묶인 글만 따로 모아, 주제별 흐름을 바로 따라갈 수 있게 정리했습니다.
      </p>
      <p class="site-page-hero__meta">
        {
          posts.length > 0
            ? `현재 ${posts.length}개의 글이 연결되어 있으며, 최신 글부터 먼저 확인할 수 있습니다.`
            : "아직 연결된 글이 없어 첫 글을 준비 중입니다."
        }
      </p>
    </div>

    {
      allTags.length > 1 && (
        <nav class="site-blog-tag-page__nav" aria-label="블로그 태그">
          <ul class="site-blog-tag-page__tag-list">
            {allTags.map((tag) => (
              <li>
                <a
                  href={tag.href}
                  class:list={[
                    "site-blog-tag-page__tag-link",
                    "site-badge",
                    tag.slug === selectedTag.slug ? "site-badge--primary" : "site-badge--neutral",
                  ]}
                  aria-current={tag.slug === selectedTag.slug ? "page" : undefined}
                >
                  {tag.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    {
      posts.length > 0 ? (
        <section
          class="site-blog-tag-page__section"
          aria-labelledby="tag-posts-heading"
          data-reveal="slide-up"
        >
          <div class="site-section-header site-blog-tag-page__section-header">
            <p class="site-section-header__eyebrow">Filtered Posts</p>
            <div class="site-section-header__rule" aria-hidden="true" />
            <h2 id="tag-posts-heading" class="site-section-header__title">
              #{selectedTag.label}와 연결된 글
            </h2>
            <p class="site-section-header__lead">
              같은 키워드로 이어지는 글만 모아 순서대로 읽을 수 있습니다.
            </p>
          </div>

          <ul class="site-blog-tag-page__posts">
            {posts.map((post) => (
              <li class="site-blog-tag-page__post-item">
                <article class="site-blog-tag-page__post site-card">
                  <div class="site-blog-tag-page__post-meta">
                    <time datetime={post.data.publishedDate.toISOString()}>
                      {formatDate(post.data.publishedDate)}
                    </time>
                  </div>

                  <h3 class="site-blog-tag-page__post-title">
                    <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
                  </h3>

                  <p class="site-blog-tag-page__post-description">{post.data.description}</p>

                  {post.data.tags.length > 0 && (
                    <ul class="site-blog-tag-page__tag-list" aria-label="포스트 태그">
                      {post.data.tags.map((tagLabel: string) => {
                        const tag = getBlogTagDescriptor(tagLabel);
                        const isCurrentTag = tag.slug === selectedTag.slug;

                        return (
                          <li>
                            <a
                              href={tag.href}
                              class:list={[
                                "site-blog-tag-page__tag-link",
                                "site-badge",
                                isCurrentTag ? "site-badge--primary" : "site-badge--neutral",
                              ]}
                            >
                              {tag.label}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  )}
                </article>
              </li>
            ))}
          </ul>
        </section>
      ) : (
        <div class="site-blog-tag-page__empty site-card" data-reveal="fade-in">
          <h2 class="site-blog-tag-page__empty-title">아직 연결된 글이 없습니다</h2>
          <p class="site-blog-tag-page__empty-text">
            같은 태그의 글이 준비되면 이 페이지에서 묶어서 확인할 수 있습니다.
          </p>
          <a href={withBase("/blog/")} class="site-button site-button--primary">
            블로그 목록 보기
          </a>
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  .site-blog-tag-page {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
    padding: clamp(var(--space-2xl), 6vw, var(--space-4xl)) var(--site-gutter) var(--space-4xl);
  }

  .site-blog-tag-page__hero {
    margin-bottom: clamp(var(--space-xl), 4vw, var(--space-2xl));
  }

  .site-blog-tag-page__back {
    width: fit-content;
    margin-bottom: var(--space-lg);
  }

  .site-blog-tag-page__nav {
    margin-bottom: clamp(var(--space-xl), 4vw, var(--space-2xl));
  }

  .site-blog-tag-page__tag-list,
  .site-blog-tag-page__posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-blog-tag-page__tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .site-blog-tag-page__tag-link {
    text-decoration: none;
  }

  .site-blog-tag-page__tag-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .site-blog-tag-page__section-header {
    margin-bottom: var(--space-lg);
  }

  .site-blog-tag-page__posts {
    display: grid;
    gap: var(--space-md);
  }

  .site-blog-tag-page__post {
    display: grid;
    gap: var(--space-sm);
    padding: clamp(var(--space-lg), 3vw, var(--space-xl));
    background: var(--site-surface-elevated);
  }

  .site-blog-tag-page__post-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .site-blog-tag-page__post-title {
    margin: 0;
    font-size: clamp(var(--text-xl), 2.4vw, var(--text-2xl));
    line-height: 1.24;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .site-blog-tag-page__post-title a {
    color: inherit;
    text-decoration: none;
  }

  .site-blog-tag-page__post-title a:hover,
  .site-blog-tag-page__post-title a:focus-visible {
    color: var(--color-primary);
  }

  .site-blog-tag-page__post-description {
    margin: 0;
    max-width: 64ch;
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .site-blog-tag-page__empty {
    display: grid;
    gap: var(--space-sm);
    justify-items: start;
    padding: clamp(var(--space-xl), 4vw, var(--space-2xl));
    background: var(--site-surface-elevated);
  }

  .site-blog-tag-page__empty-title {
    margin: 0;
    font-size: clamp(var(--text-xl), 3vw, var(--text-2xl));
    color: var(--color-ink);
  }

  .site-blog-tag-page__empty-text {
    margin: 0;
    max-width: 54ch;
    line-height: 1.75;
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .site-blog-tag-page__posts {
      gap: var(--space-lg);
    }
  }
</style>
