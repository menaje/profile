---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", (entry: CollectionEntry<"blog">) => {
    return import.meta.env.PROD ? entry.data.draft !== true : true;
  });

  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await render(post);
const titleTransitionName = `blog-post-title-${post.id}`;
const dateTransitionName = `blog-post-date-${post.id}`;

function formatDate(date: Date): string {
  return date.toLocaleDateString("ko-KR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function getDateBlockParts(date: Date) {
  return {
    month: `${date.getMonth() + 1}`.padStart(2, "0"),
    day: `${date.getDate()}`.padStart(2, "0"),
    year: `${date.getFullYear()}`,
  };
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.ogImage}
>
  <article class="site-blog-post">
    <section class="site-blog-post__hero">
      <div class="site-blog-post__hero-inner">
        <a
          href={withBase("/blog/")}
          class="site-blog-post__back site-button site-button--ghost site-button--quiet"
          data-reveal="slide-in-left"
        >
          <span aria-hidden="true">←</span>
          <span>블로그 목록</span>
        </a>

        <div class="site-blog-post__hero-grid" data-reveal="slide-up">
          <time
            class="site-blog-post__date-block"
            datetime={post.data.publishedDate.toISOString()}
            aria-label={formatDate(post.data.publishedDate)}
            style={`view-transition-name: ${dateTransitionName}`}
          >
            <span class="site-blog-post__date-month">
              {getDateBlockParts(post.data.publishedDate).month}
            </span>
            <strong class="site-blog-post__date-day">
              {getDateBlockParts(post.data.publishedDate).day}
            </strong>
            <span class="site-blog-post__date-year">
              {getDateBlockParts(post.data.publishedDate).year}
            </span>
          </time>

          <div class="site-page-hero site-blog-post__hero-copy">
            <p class="site-page-hero__eyebrow">Journal Entry</p>
            <h1
              class="site-page-hero__title"
              style={`view-transition-name: ${titleTransitionName}`}
            >
              {post.data.title}
            </h1>
            <p class="site-page-hero__lead">{post.data.description}</p>
          </div>
        </div>

        <dl class="site-metadata-block site-blog-post__metadata" data-reveal="slide-up">
          <div class="site-metadata-block__item">
            <dt>Published</dt>
            <dd>
              <time datetime={post.data.publishedDate.toISOString()}>
                {formatDate(post.data.publishedDate)}
              </time>
            </dd>
          </div>

          {
            post.data.updatedDate && (
              <div class="site-metadata-block__item">
                <dt>Updated</dt>
                <dd>
                  <time datetime={post.data.updatedDate.toISOString()}>
                    {formatDate(post.data.updatedDate)}
                  </time>
                </dd>
              </div>
            )
          }

          {
            post.data.tags.length > 0 && (
              <div class="site-metadata-block__item">
                <dt>Tags</dt>
                <dd>
                  <ul class="site-blog-post__tag-list" aria-label="태그">
                    {post.data.tags.map((tag: string) => (
                      <li>
                        <span class="site-badge site-badge--neutral">{tag}</span>
                      </li>
                    ))}
                  </ul>
                </dd>
              </div>
            )
          }
        </dl>
      </div>
    </section>

    <div class="site-blog-post__article-shell">
      <div class="site-blog-post__article-card site-card">
        <div class="site-blog-post__content">
          <Content />
        </div>
      </div>
    </div>

    <footer class="site-blog-post__footer" data-reveal="fade-in">
      <div class="site-blog-post__footer-card site-card">
        <div class="site-blog-post__footer-copy">
          <p class="site-blog-post__footer-eyebrow">Continue Reading</p>
          <h2 class="site-blog-post__footer-title">목록으로 돌아가 더 많은 기록을 둘러보세요.</h2>
          <p class="site-blog-post__footer-text">
            다음 글이 추가되면 같은 리듬으로 이어집니다. 지금은 블로그 목록에서 최신 글과 아카이브를
            함께 확인할 수 있습니다.
          </p>
        </div>
        <a href={withBase("/blog/")} class="site-button site-button--primary"> 블로그 목록 보기 </a>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .site-blog-post {
    padding-bottom: clamp(var(--space-3xl), 6vw, var(--space-5xl));
  }

  .site-blog-post__hero {
    padding: clamp(var(--space-2xl), 6vw, var(--space-4xl)) var(--site-gutter) var(--space-xl);
  }

  .site-blog-post__hero-inner,
  .site-blog-post__article-shell,
  .site-blog-post__footer {
    max-width: 72rem;
    margin: 0 auto;
  }

  .site-blog-post__back {
    width: fit-content;
    margin-bottom: var(--space-xl);
  }

  .site-blog-post__hero-grid {
    display: grid;
    gap: var(--space-lg);
    align-items: start;
  }

  .site-blog-post__date-block {
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 0.16rem;
    width: min(100%, 6.25rem);
    padding: var(--space-lg) var(--space-md);
    border: 1px solid var(--site-border-default);
    border-radius: var(--site-card-radius);
    background: var(--site-surface-muted);
    color: var(--color-primary);
    text-align: center;
  }

  .site-blog-post__date-month,
  .site-blog-post__date-year {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.16em;
    line-height: 1;
  }

  .site-blog-post__date-month {
    opacity: 0.76;
  }

  .site-blog-post__date-day {
    font-size: clamp(1.85rem, 1.4rem + 1vw, 2.6rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .site-blog-post__date-year {
    letter-spacing: 0.08em;
    opacity: 0.72;
  }

  .site-blog-post__hero-copy {
    margin-bottom: 0;
  }

  .site-blog-post__metadata {
    margin-top: var(--space-xl);
  }

  .site-blog-post__tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: 0;
    padding: 0;
  }

  .site-blog-post__article-shell {
    padding: 0 var(--site-gutter);
  }

  .site-blog-post__article-card {
    gap: 0;
    max-width: 58rem;
    margin: 0 auto;
    padding: clamp(var(--space-xl), 4vw, var(--space-3xl));
    border-color: var(--site-border-default);
    background: var(--site-surface-elevated);
    box-shadow: var(--site-shadow-flat);
  }

  .site-blog-post__content {
    color: var(--color-text-secondary);
    font-size: clamp(var(--text-md), 0.98rem + 0.3vw, var(--text-lg));
    line-height: 1.9;
  }

  .site-blog-post__content
    :global(:where(h2, h3, h4, p, ul, ol, blockquote, pre, table, figure, hr)) {
    margin-top: 0;
    margin-bottom: var(--space-lg);
  }

  .site-blog-post__content :global(h2),
  .site-blog-post__content :global(h3),
  .site-blog-post__content :global(h4) {
    color: var(--color-ink);
    scroll-margin-top: 7rem;
    text-wrap: balance;
  }

  .site-blog-post__content :global(h2) {
    margin-top: clamp(var(--space-2xl), 4vw, var(--space-4xl));
    font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
    line-height: 1.16;
  }

  .site-blog-post__content :global(h3) {
    margin-top: var(--space-2xl);
    font-size: clamp(var(--text-xl), 2vw, var(--text-2xl));
    line-height: 1.22;
  }

  .site-blog-post__content :global(h4) {
    margin-top: var(--space-xl);
    font-size: var(--text-lg);
    line-height: 1.35;
  }

  .site-blog-post__content :global(p) {
    max-width: 66ch;
  }

  .site-blog-post__content :global(ul),
  .site-blog-post__content :global(ol) {
    padding-left: clamp(1.35rem, 1.1rem + 1vw, 2rem);
  }

  .site-blog-post__content :global(li) {
    color: var(--color-text-secondary);
    padding-left: var(--space-2xs);
  }

  .site-blog-post__content :global(li + li) {
    margin-top: var(--space-xs);
  }

  .site-blog-post__content :global(blockquote) {
    position: relative;
    padding: var(--space-lg) var(--space-xl) var(--space-lg) calc(var(--space-xl) + var(--space-xs));
    border: 1px solid var(--site-border-default);
    border-left: 4px solid var(--color-secondary);
    border-radius: var(--site-card-radius);
    background: var(--site-surface-muted);
    color: var(--color-text);
  }

  .site-blog-post__content :global(blockquote)::before {
    content: "“";
    position: absolute;
    top: 0.15rem;
    left: var(--space-sm);
    font-size: 3rem;
    line-height: 1;
    color: color-mix(in srgb, var(--color-text-muted) 30%, transparent);
  }

  .site-blog-post__content :global(blockquote p:last-child),
  .site-blog-post__content :global(li > p:last-child) {
    margin-bottom: 0;
  }

  .site-blog-post__content :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }

  .site-blog-post__content :global(a) {
    color: var(--color-primary);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
    transition: color var(--transition-fast);
  }

  .site-blog-post__content :global(a:hover) {
    color: var(--color-ink);
  }

  .site-blog-post__content :global(:not(pre) > code) {
    padding: 0.18em 0.45em;
    border: 1px solid var(--site-border-default);
    border-radius: var(--radius-sm);
    background: var(--site-surface-muted);
    color: var(--color-text);
    font-family: var(--font-family-mono);
    font-size: 0.88em;
  }

  .site-blog-post__content :global(pre),
  .site-blog-post__content :global(pre.astro-code) {
    position: relative;
    overflow-x: auto;
    padding: var(--space-lg);
    border: 1px solid var(--site-border-default);
    border-radius: var(--site-card-radius);
    background: color-mix(in srgb, var(--color-ink) 94%, black) !important;
    font-family: var(--font-family-mono);
    font-size: clamp(0.82rem, 0.78rem + 0.15vw, 0.94rem);
    line-height: 1.8;
  }

  .site-blog-post__content :global(pre)::before,
  .site-blog-post__content :global(pre.astro-code)::before {
    display: none;
  }

  .site-blog-post__content :global(pre code) {
    display: block;
    min-width: max-content;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    font-family: inherit;
  }

  .site-blog-post__content :global(hr) {
    border: 0;
    border-top: 1px solid var(--site-border-default);
    margin-block: clamp(var(--space-xl), 4vw, var(--space-3xl));
  }

  .site-blog-post__content :global(table) {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    border-spacing: 0;
    border: 1px solid var(--site-border-default);
    border-radius: var(--site-card-radius);
    background: var(--site-surface-muted);
  }

  .site-blog-post__content :global(th),
  .site-blog-post__content :global(td) {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--site-border-default);
    text-align: left;
    white-space: nowrap;
  }

  .site-blog-post__content :global(th) {
    color: var(--color-ink);
    background: var(--site-surface-muted);
  }

  .site-blog-post__content :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--site-border-default);
    border-radius: var(--site-card-radius);
  }

  .site-blog-post__content :global(figure) {
    display: grid;
    gap: var(--space-sm);
  }

  .site-blog-post__content :global(figcaption) {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  .site-blog-post__content :global(.blog-visual),
  .site-blog-post__content :global(.blog-flow),
  .site-blog-post__content :global(.blog-compare-grid),
  .site-blog-post__content :global(.blog-filter-grid),
  .site-blog-post__content :global(.blog-policy-grid),
  .site-blog-post__content :global(.blog-evidence-grid),
  .site-blog-post__content :global(.blog-system-grid),
  .site-blog-post__content :global(.blog-common-grid) {
    max-width: none;
  }

  .site-blog-post__content :global(.blog-visual) {
    display: grid;
    gap: var(--space-lg);
    padding: clamp(var(--space-lg), 3vw, var(--space-xl));
    border: 1px solid var(--site-border-default);
    border-radius: calc(var(--site-card-radius) + var(--space-2xs));
    background: color-mix(in srgb, var(--site-surface-default) 60%, var(--site-surface-muted));
  }

  .site-blog-post__content :global(.blog-visual--summary) {
    border-color: var(--site-border-accent);
    background: color-mix(in srgb, var(--color-primary) 4%, var(--site-surface-default));
  }

  .site-blog-post__content :global(.blog-visual__intro) {
    display: grid;
    gap: var(--space-sm);
  }

  .site-blog-post__content :global(.blog-visual__title),
  .site-blog-post__content :global(.blog-issue-card__title),
  .site-blog-post__content :global(.blog-compare-card__title),
  .site-blog-post__content :global(.blog-flow-card__title) {
    margin: 0;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .site-blog-post__content :global(.blog-visual__title) {
    font-size: clamp(var(--text-xl), 2vw, var(--text-2xl));
    line-height: 1.25;
  }

  .site-blog-post__content :global(.blog-visual__lead),
  .site-blog-post__content :global(.blog-issue-card__summary),
  .site-blog-post__content :global(.blog-flow-card__text) {
    max-width: none;
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .site-blog-post__content :global(.blog-chip-row) {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .site-blog-post__content :global(.blog-issue-grid),
  .site-blog-post__content :global(.blog-compare-grid),
  .site-blog-post__content :global(.blog-filter-grid),
  .site-blog-post__content :global(.blog-policy-grid),
  .site-blog-post__content :global(.blog-evidence-grid),
  .site-blog-post__content :global(.blog-system-grid),
  .site-blog-post__content :global(.blog-common-grid) {
    display: grid;
    gap: var(--space-md);
  }

  .site-blog-post__content :global(.blog-issue-card),
  .site-blog-post__content :global(.blog-compare-card),
  .site-blog-post__content :global(.blog-flow-card),
  .site-blog-post__content :global(.blog-filter-card),
  .site-blog-post__content :global(.blog-policy-card),
  .site-blog-post__content :global(.blog-evidence-card),
  .site-blog-post__content :global(.blog-system-card),
  .site-blog-post__content :global(.blog-common-card) {
    height: 100%;
    background: var(--site-surface-default);
  }

  .site-blog-post__content :global(.blog-issue-card__title) {
    font-size: var(--text-lg);
    line-height: 1.3;
  }

  .site-blog-post__content :global(.blog-compare-card) {
    gap: var(--space-sm);
  }

  .site-blog-post__content :global(.blog-compare-card--focus) {
    border-color: var(--site-border-accent);
    background: color-mix(in srgb, var(--color-primary) 4%, var(--site-surface-default));
  }

  .site-blog-post__content :global(.blog-compare-card__eyebrow) {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-blog-post__content :global(.blog-compare-card__title) {
    font-size: clamp(var(--text-lg), 1.6vw, var(--text-xl));
    line-height: 1.3;
  }

  .site-blog-post__content :global(.blog-compare-card__list),
  .site-blog-post__content :global(.blog-filter-card__list) {
    max-width: none;
    margin: 0;
    padding-left: 1.2rem;
  }

  .site-blog-post__content :global(.blog-flow) {
    display: grid;
    gap: var(--space-sm);
    align-items: stretch;
  }

  .site-blog-post__content :global(.blog-flow__arrow) {
    display: grid;
    place-items: center;
    min-height: 2.5rem;
    color: var(--color-primary);
    font-size: 1.5rem;
    font-weight: 700;
    transform: rotate(90deg);
  }

  .site-blog-post__content :global(.blog-flow-card) {
    gap: var(--space-sm);
  }

  .site-blog-post__content :global(.blog-flow-card__title) {
    font-size: clamp(var(--text-lg), 1.4vw, var(--text-xl));
    line-height: 1.28;
  }

  .site-blog-post__content :global(.blog-filter-card) {
    gap: var(--space-sm);
  }

  .site-blog-post__content :global(.blog-policy-card),
  .site-blog-post__content :global(.blog-evidence-card) {
    gap: var(--space-sm);
  }

  .site-blog-post__content :global(.blog-policy-card--performance) {
    border-color: color-mix(in srgb, var(--color-secondary) 30%, var(--site-border-default));
    background: color-mix(in srgb, var(--color-secondary) 4%, var(--site-surface-default));
  }

  .site-blog-post__content :global(.blog-policy-card--data) {
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--site-border-default));
    background: color-mix(in srgb, var(--color-accent) 4%, var(--site-surface-default));
  }

  .site-blog-post__content :global(.blog-policy-card--hybrid),
  .site-blog-post__content :global(.blog-evidence-card--accent) {
    border-color: color-mix(in srgb, var(--color-primary) 28%, var(--site-border-default));
    background: color-mix(in srgb, var(--color-primary) 4%, var(--site-surface-default));
  }

  .site-blog-post__content :global(.blog-policy-card__title),
  .site-blog-post__content :global(.blog-evidence-card__title) {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(var(--text-lg), 1.5vw, var(--text-xl));
    line-height: 1.3;
    text-wrap: balance;
  }

  .site-blog-post__content :global(.blog-policy-card__summary),
  .site-blog-post__content :global(.blog-evidence-card__text) {
    max-width: none;
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.72;
    color: var(--color-text-secondary);
  }

  .site-blog-post__content :global(.blog-policy-card__list) {
    max-width: none;
    margin: 0;
    padding-left: 1.2rem;
  }

  .site-blog-post__content :global(.blog-system-card),
  .site-blog-post__content :global(.blog-common-card) {
    gap: var(--space-sm);
  }

  .site-blog-post__content :global(.blog-system-card__title) {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(var(--text-lg), 1.6vw, var(--text-xl));
    line-height: 1.28;
    text-wrap: balance;
  }

  .site-blog-post__content :global(.blog-system-card__summary),
  .site-blog-post__content :global(.blog-common-card__text) {
    max-width: none;
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.72;
    color: var(--color-text-secondary);
  }

  .site-blog-post__content :global(.blog-system-card__list) {
    max-width: none;
    margin: 0;
    padding-left: 1.2rem;
  }

  .site-blog-post__footer {
    padding: var(--space-2xl) var(--site-gutter) 0;
  }

  .site-blog-post__footer-card {
    gap: var(--space-lg);
    max-width: 58rem;
    margin: 0 auto;
    padding: clamp(var(--space-lg), 3vw, var(--space-xl));
  }

  .site-blog-post__footer-copy {
    display: grid;
    gap: var(--space-xs);
  }

  .site-blog-post__footer-eyebrow {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-blog-post__footer-title {
    margin: 0;
    font-size: clamp(var(--text-xl), 2vw, var(--text-2xl));
    line-height: 1.22;
    color: var(--color-ink);
    text-wrap: balance;
  }

  .site-blog-post__footer-text {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: 1.7;
  }

  @media (min-width: 768px) {
    .site-blog-post__hero {
      padding-bottom: var(--space-2xl);
    }

    .site-blog-post__hero-grid {
      grid-template-columns: minmax(6rem, 6.5rem) minmax(0, 1fr);
      gap: var(--space-xl);
    }

    .site-blog-post__metadata {
      margin-top: var(--space-2xl);
    }

    .site-blog-post__article-card {
      padding-inline: clamp(var(--space-xl), 4vw, var(--space-3xl));
    }

    .site-blog-post__content :global(.blog-issue-grid) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .site-blog-post__content :global(.blog-compare-grid),
    .site-blog-post__content :global(.blog-filter-grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
