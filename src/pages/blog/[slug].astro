---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", (entry: CollectionEntry<"blog">) => {
    return import.meta.env.PROD ? entry.data.draft !== true : true;
  });

  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString("ko-KR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  ogImage={post.data.ogImage}
>
  <article class="site-blog-post">
    <header class="site-blog-post__header">
      <a href="/blog/" class="site-blog-post__back">&larr; 블로그 목록</a>
      <h1 class="site-blog-post__title">{post.data.title}</h1>
      <div class="site-blog-post__meta">
        <time datetime={post.data.publishedDate.toISOString()}>
          {formatDate(post.data.publishedDate)}
        </time>
        {
          post.data.updatedDate && (
            <span class="site-blog-post__updated">
              (수정: {formatDate(post.data.updatedDate)})
            </span>
          )
        }
      </div>
      {
        post.data.tags.length > 0 && (
          <ul class="site-blog-post__tags">
            {post.data.tags.map((tag: string) => (
              <li class="site-blog-post__tag">{tag}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="site-blog-post__content">
      <Content />
    </div>

    <footer class="site-blog-post__footer">
      <a href="/blog/" class="site-blog-post__back">&larr; 블로그 목록으로</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .site-blog-post {
    max-width: 42rem;
    margin: 0 auto;
    padding: var(--space-xl) var(--site-gutter) var(--space-2xl);
  }

  /* ── Header ── */
  .site-blog-post__header {
    margin-bottom: var(--space-xl);
  }

  .site-blog-post__back {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: var(--space-lg);
    transition: color var(--transition-fast);
  }

  .site-blog-post__back:hover {
    color: var(--color-primary);
  }

  .site-blog-post__title {
    font-size: var(--text-3xl);
    line-height: 1.3;
    margin: 0 0 var(--space-sm);
    color: var(--color-ink);
  }

  .site-blog-post__meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .site-blog-post__updated {
    margin-left: var(--space-xs);
  }

  .site-blog-post__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .site-blog-post__tag {
    font-size: var(--text-xs);
    color: var(--color-primary);
    background: var(--color-bg-surface);
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
  }

  /* ── Article content (MDX rendered) ── */
  .site-blog-post__content {
    line-height: 1.8;
    color: var(--color-ink);
  }

  .site-blog-post__content :global(h2) {
    font-size: var(--text-2xl);
    margin: var(--space-2xl) 0 var(--space-md);
    color: var(--color-ink);
    line-height: 1.3;
  }

  .site-blog-post__content :global(h3) {
    font-size: var(--text-xl);
    margin: var(--space-xl) 0 var(--space-sm);
    color: var(--color-ink);
    line-height: 1.4;
  }

  .site-blog-post__content :global(p) {
    margin: 0 0 var(--space-md);
    color: var(--color-ink);
  }

  .site-blog-post__content :global(ul),
  .site-blog-post__content :global(ol) {
    margin: 0 0 var(--space-md);
    padding-left: var(--space-lg);
  }

  .site-blog-post__content :global(li) {
    margin-bottom: var(--space-xs);
    color: var(--color-ink);
  }

  .site-blog-post__content :global(blockquote) {
    margin: var(--space-lg) 0;
    padding: var(--space-md) var(--space-lg);
    border-left: 3px solid var(--color-primary);
    background: var(--color-bg-surface);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .site-blog-post__content :global(blockquote p) {
    margin: 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .site-blog-post__content :global(code) {
    font-size: 0.9em;
    background: var(--color-bg-surface);
    padding: 2px var(--space-xs);
    border-radius: var(--radius-sm);
  }

  .site-blog-post__content :global(pre) {
    margin: 0 0 var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-ink);
    color: var(--color-paper);
    border-radius: var(--radius-md);
    overflow-x: auto;
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .site-blog-post__content :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    color: inherit;
  }

  .site-blog-post__content :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }

  .site-blog-post__content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .site-blog-post__content :global(a:hover) {
    color: var(--color-ink);
  }

  .site-blog-post__content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-line);
    margin: var(--space-xl) 0;
  }

  /* ── Footer ── */
  .site-blog-post__footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-line);
  }

  @media (min-width: 768px) {
    .site-blog-post {
      padding-top: var(--space-2xl);
    }

    .site-blog-post__title {
      font-size: var(--text-4xl);
    }
  }
</style>
