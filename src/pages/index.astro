---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildPersonStructuredData, buildWebsiteStructuredData } from "../lib/structured-data";
import HeroSection from "../components/HeroSection.astro";
import ProofStrip from "../components/ProofStrip.astro";
import SelectedWork from "../components/SelectedWork.astro";
import CareerTimeline from "../components/CareerTimeline.astro";
import CtaSection from "../components/CtaSection.astro";
import { getPublicProfile } from "../lib/public-profile";
import { getFallbackSiteUrl } from "../lib/site";

const data = getPublicProfile();
const pageTitle = "김성식 — AI 네이티브 시스템 아키텍트";
const pageDescription =
  "건설CM 9년 + AI/IT 경력을 바탕으로 도메인 문제를 AI 협업 시스템으로 번역하는 시스템 아키텍트입니다.";
const site = Astro.site ?? getFallbackSiteUrl();
const structuredData = [
  buildPersonStructuredData({
    site,
    profile: data.profile,
    description: pageDescription,
  }),
  buildWebsiteStructuredData({
    site,
    profile: data.profile,
    description: pageDescription,
  }),
];
---

<BaseLayout title={pageTitle} description={pageDescription} structuredData={structuredData}>
  <HeroSection profile={data.profile} currentStatus={data.currentStatus} />
  <ProofStrip careerSummary={data.careerSummary} />
  <SelectedWork projects={data.projects.core} organizations={data.organizations} />
  <CareerTimeline
    employmentTimeline={data.employmentTimeline}
    organizations={data.organizations}
    projects={data.projects.core}
    supportingProjects={data.projects.supporting}
  />
  <CtaSection profile={data.profile} currentStatus={data.currentStatus} />
</BaseLayout>
