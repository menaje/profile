---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublicProfile } from "../lib/public-profile";

const profile = getPublicProfile();
const { github, linkedin } = profile.profile.contacts;
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID ?? "";
---

<BaseLayout
  title="연락처 — 김성식"
  description="김성식에게 연락하기. 문의 폼 또는 GitHub, LinkedIn을 통해 연결하세요."
>
  <section class="site-contact">
    <h1 class="site-contact__title">연락처</h1>
    <p class="site-contact__intro">
      프로젝트 협업, 채용 문의, 또는 궁금한 점이 있으시면 아래 폼으로 메시지를
      보내주세요.
    </p>

    <div class="site-contact__grid">
      <div class="site-contact__info">
        <h2 class="site-contact__subtitle">다른 채널</h2>
        <div class="site-contact__social">
          <a
            href={github.url}
            target="_blank"
            rel="noopener noreferrer"
            class="site-contact__link"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
              ></path>
              <path d="M9 18c-4.51 2-5-2-7-2"></path>
            </svg>
            GitHub
          </a>
          <a
            href={linkedin.url}
            target="_blank"
            rel="noopener noreferrer"
            class="site-contact__link"
          >
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
              ></path>
              <rect width="4" height="12" x="2" y="9"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>

      <div class="site-contact__form-wrapper">
        <h2 class="site-contact__subtitle">메시지 보내기</h2>
        <form
          class="site-contact__form"
          action={formspreeId ? `https://formspree.io/f/${formspreeId}` : "#"}
          data-configured={formspreeId ? "true" : "false"}
          method="POST"
        >
          <div class="site-contact__field">
            <label for="contact-name">이름</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
            />
          </div>

          <div class="site-contact__field">
            <label for="contact-email">이메일</label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
            />
          </div>

          <div class="site-contact__field">
            <label for="contact-message">메시지</label>
            <textarea
              id="contact-message"
              name="message"
              rows="6"
              required></textarea>
          </div>

          <!-- Honeypot spam prevention -->
          <input
            type="text"
            name="_gotcha"
            style="display:none"
            tabindex="-1"
            autocomplete="off"
          />

          <button type="submit" class="site-contact__submit">
            메시지 보내기
          </button>
        </form>

        <div
          class="site-contact__feedback"
          aria-live="polite"
          hidden
        >
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>(".site-contact__form");
  const feedback = document.querySelector<HTMLDivElement>(
    ".site-contact__feedback",
  );
  const submitBtn = document.querySelector<HTMLButtonElement>(
    ".site-contact__submit",
  );

  if (form && feedback && submitBtn) {
    const originalText = submitBtn.textContent;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (form.dataset.configured !== "true") {
        feedback.textContent =
          "폼이 아직 설정되지 않았습니다. GitHub 또는 LinkedIn으로 연락해주세요.";
        feedback.className = "site-contact__feedback site-contact__feedback--error";
        feedback.hidden = false;
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "전송 중...";
      feedback.hidden = true;

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });

        if (res.ok) {
          form.reset();
          feedback.textContent =
            "메시지가 성공적으로 전송되었습니다. 감사합니다!";
          feedback.className = "site-contact__feedback site-contact__feedback--success";
        } else {
          feedback.textContent =
            "전송에 실패했습니다. 잠시 후 다시 시도해주세요.";
          feedback.className = "site-contact__feedback site-contact__feedback--error";
        }
      } catch {
        feedback.textContent =
          "전송에 실패했습니다. 네트워크 연결을 확인해주세요.";
        feedback.className = "site-contact__feedback site-contact__feedback--error";
      } finally {
        feedback.hidden = false;
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;

        setTimeout(() => {
          feedback.hidden = true;
        }, 5000);
      }
    });
  }
</script>

<style>
  .site-contact {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
    padding: var(--space-2xl) var(--site-gutter);
  }

  .site-contact__title {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-sm);
  }

  .site-contact__intro {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    margin: 0 0 var(--space-2xl);
    max-width: 40rem;
  }

  .site-contact__grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .site-contact__subtitle {
    font-size: var(--text-xl);
    margin: 0 0 var(--space-md);
  }

  .site-contact__social {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .site-contact__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-base);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-md);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .site-contact__link:hover {
    color: var(--color-primary);
    background-color: var(--color-bg-surface);
  }

  .site-contact__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .site-contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .site-contact__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .site-contact__field label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .site-contact__field input,
  .site-contact__field textarea {
    width: 100%;
    padding: var(--space-sm);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-paper);
    transition: border-color var(--transition-fast);
  }

  .site-contact__field input:focus,
  .site-contact__field textarea:focus {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
    border-color: var(--color-primary);
  }

  .site-contact__field textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .site-contact__submit {
    align-self: flex-start;
    padding: var(--space-sm) var(--space-xl);
    background: var(--color-primary);
    color: var(--color-paper);
    border: none;
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-base);
    font-weight: 600;
    cursor: pointer;
    transition:
      opacity var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-contact__submit:hover {
    opacity: 0.9;
    transform: var(--hover-lift);
  }

  .site-contact__submit:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .site-contact__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .site-contact__feedback {
    margin-top: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
  }

  .site-contact__feedback--success {
    background: color-mix(in srgb, #16a34a 10%, transparent);
    color: #15803d;
    border: 1px solid color-mix(in srgb, #16a34a 25%, transparent);
  }

  .site-contact__feedback--error {
    background: color-mix(in srgb, #dc2626 10%, transparent);
    color: #b91c1c;
    border: 1px solid color-mix(in srgb, #dc2626 25%, transparent);
  }

  @media (min-width: 768px) {
    .site-contact__grid {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: var(--space-3xl);
      align-items: start;
    }

    .site-contact__social {
      position: sticky;
      top: calc(var(--site-nav-height) + var(--space-lg));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-contact__submit {
      transition: none;
    }

    .site-contact__submit:hover {
      transform: none;
    }

    .site-contact__link {
      transition: none;
    }

    .site-contact__field input,
    .site-contact__field textarea {
      transition: none;
    }
  }
</style>
