---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublicProfile } from "../lib/public-profile";
import { buildBreadcrumbStructuredData } from "../lib/structured-data";
import { getFallbackSiteUrl } from "../lib/site";

const data = getPublicProfile();
const { currentStatus } = data;
const { name, positioningTitle, contacts } = data.profile;
const { github, linkedin } = contacts;
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID ?? "";
const pageTitle = "연락처 — 김성식";
const pageDescription = "김성식에게 연락하기. 문의 폼 또는 GitHub, LinkedIn을 통해 연결하세요.";
const site = Astro.site ?? getFallbackSiteUrl();
const structuredData = buildBreadcrumbStructuredData({
  site,
  items: [
    { name: "홈", path: "/" },
    { name: "연락처", path: "/contact/" },
  ],
});

const contactMetadata = [
  {
    term: "현재 상태",
    value: currentStatus.display,
  },
  {
    term: "연결 채널",
    value: "문의 폼, GitHub, LinkedIn",
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription} structuredData={structuredData}>
  <section class="site-contact">
    <header class="site-contact__hero site-page-hero" data-reveal="slide-up">
      <p class="site-page-hero__eyebrow">Contact</p>
      <h1 class="site-contact__title site-page-hero__title">연락처</h1>
      <p class="site-contact__intro site-page-hero__lead">
        프로젝트 협업, 채용 문의, 혹은 시스템 설계와 자동화에 대한 이야기가 필요하시면 아래 폼으로
        편하게 메시지를 보내주세요.
      </p>
      <p class="site-contact__meta site-page-hero__meta">
        문의 폼이 준비되지 않은 환경에서는 GitHub 또는 LinkedIn으로 바로 연결할 수 있습니다.
      </p>
    </header>

    <div class="site-contact__grid">
      <div
        class="site-contact__form-card site-card"
        data-reveal="slide-up"
        style="--site-reveal-delay: 90ms;"
      >
        <div class="site-contact__form-header site-section-header">
          <p class="site-contact__form-eyebrow site-section-header__eyebrow">Message</p>
          <div class="site-section-header__rule" aria-hidden="true"></div>
          <h2 class="site-contact__form-title site-section-header__title">메시지 보내기</h2>
          <p class="site-contact__form-lead site-section-header__lead">
            간단한 소개와 함께 필요한 맥락을 남겨주시면 확인 후 답변드리겠습니다.
          </p>
        </div>

        <form
          class="site-contact__form"
          action={formspreeId ? `https://formspree.io/f/${formspreeId}` : "#"}
          data-configured={formspreeId ? "true" : "false"}
          method="POST"
        >
          <div class="site-contact__field site-form-field">
            <label for="contact-name" class="site-form-field__label">이름</label>
            <input
              class="site-form-field__control"
              type="text"
              id="contact-name"
              name="name"
              required
              autocomplete="name"
            />
          </div>

          <div class="site-contact__field site-form-field">
            <label for="contact-email" class="site-form-field__label"> 이메일 </label>
            <input
              class="site-form-field__control"
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
            />
          </div>

          <div class="site-contact__field site-form-field">
            <label for="contact-message" class="site-form-field__label"> 메시지 </label>
            <textarea
              class="site-form-field__control"
              id="contact-message"
              name="message"
              rows="6"
              required></textarea>
          </div>

          <!-- Honeypot spam prevention -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

          <button
            type="submit"
            class="site-contact__submit site-button site-button--primary site-button--glow site-button--full"
          >
            메시지 보내기
          </button>
        </form>

        <div class="site-contact__feedback" aria-live="polite" data-state="idle" hidden>
          <div class="site-contact__feedback-icon" aria-hidden="true">
            <svg
              class="site-contact__feedback-symbol site-contact__feedback-symbol--success"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 6 9 17l-5-5"></path>
            </svg>
            <svg
              class="site-contact__feedback-symbol site-contact__feedback-symbol--error"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 9v4"></path>
              <path d="M12 17h.01"></path>
              <path
                d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"
              ></path>
            </svg>
          </div>
          <div class="site-contact__feedback-copy">
            <p class="site-contact__feedback-title">메시지 상태</p>
            <p class="site-contact__feedback-text"></p>
          </div>
        </div>
      </div>

      <aside
        class="site-contact__sidebar"
        data-reveal="slide-up"
        style="--site-reveal-delay: 180ms;"
      >
        <article class="site-contact__profile-card site-card">
          <div class="site-contact__profile-top">
            <span class="site-badge site-badge--state">{currentStatus.label}</span>
            <p class="site-contact__profile-kicker">Profile</p>
          </div>

          <div class="site-contact__profile-header">
            <h2 class="site-contact__profile-name">{name.ko}</h2>
            <p class="site-contact__profile-title">{positioningTitle}</p>
          </div>

          <p class="site-contact__profile-copy">
            건설 현장의 맥락을 읽고, 실제 업무가 굴러가는 흐름을 AI 협업 시스템과 자동화 구조로
            번역하는 일을 합니다.
          </p>

          <dl class="site-contact__metadata site-metadata-block">
            {
              contactMetadata.map((item) => (
                <div class="site-metadata-block__item">
                  <dt>{item.term}</dt>
                  <dd>{item.value}</dd>
                </div>
              ))
            }
          </dl>

          <div class="site-contact__social-header">
            <p class="site-contact__social-title">다른 채널</p>
            <p class="site-contact__social-meta">소셜 프로필에서 작업 방식도 확인할 수 있습니다.</p>
          </div>

          <div class="site-contact__social" role="group" aria-label="소셜 링크">
            <a
              href={github.url}
              target="_blank"
              rel="noopener noreferrer"
              class="site-contact__social-link site-contact__social-link--github site-button site-button--ghost"
            >
              <span class="site-contact__social-main">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path
                    d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
                  ></path>
                  <path d="M9 18c-4.51 2-5-2-7-2"></path>
                </svg>
                <span>GitHub</span>
              </span>
              <span class="site-contact__social-action">열기</span>
            </a>

            <a
              href={linkedin.url}
              target="_blank"
              rel="noopener noreferrer"
              class="site-contact__social-link site-contact__social-link--linkedin site-button site-button--ghost"
            >
              <span class="site-contact__social-main">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path
                    d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                  ></path>
                  <rect width="4" height="12" x="2" y="9"></rect>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
                <span>LinkedIn</span>
              </span>
              <span class="site-contact__social-action">열기</span>
            </a>
          </div>
        </article>
      </aside>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector<HTMLFormElement>(".site-contact__form");
  const feedback = document.querySelector<HTMLDivElement>(".site-contact__feedback");
  const feedbackTitle = document.querySelector<HTMLParagraphElement>(
    ".site-contact__feedback-title",
  );
  const feedbackText = document.querySelector<HTMLParagraphElement>(".site-contact__feedback-text");
  const submitBtn = document.querySelector<HTMLButtonElement>(".site-contact__submit");

  if (form && feedback && feedbackTitle && feedbackText && submitBtn) {
    const originalText = submitBtn.textContent?.trim() ?? "메시지 보내기";
    let feedbackTimer: number | undefined;

    const hideFeedback = () => {
      if (feedbackTimer) {
        window.clearTimeout(feedbackTimer);
      }

      feedback.hidden = true;
      feedback.dataset.state = "idle";
    };

    const showFeedback = ({
      state,
      title,
      message,
      autoHide = true,
    }: {
      state: "success" | "error";
      title: string;
      message: string;
      autoHide?: boolean;
    }) => {
      if (feedbackTimer) {
        window.clearTimeout(feedbackTimer);
      }

      feedback.dataset.state = state;
      feedbackTitle.textContent = title;
      feedbackText.textContent = message;
      feedback.hidden = false;

      if (autoHide) {
        feedbackTimer = window.setTimeout(() => {
          hideFeedback();
        }, 5000);
      }
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (form.dataset.configured !== "true") {
        showFeedback({
          state: "error",
          title: "폼 미설정",
          message: "폼이 아직 설정되지 않았습니다. GitHub 또는 LinkedIn으로 연락해주세요.",
          autoHide: false,
        });
        return;
      }

      hideFeedback();
      submitBtn.disabled = true;
      submitBtn.textContent = "전송 중...";

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });

        if (res.ok) {
          form.reset();
          showFeedback({
            state: "success",
            title: "전송 완료",
            message: "메시지가 성공적으로 전송되었습니다. 감사합니다!",
          });
        } else {
          showFeedback({
            state: "error",
            title: "전송 실패",
            message: "전송에 실패했습니다. 잠시 후 다시 시도해주세요.",
          });
        }
      } catch {
        showFeedback({
          state: "error",
          title: "네트워크 오류",
          message: "전송에 실패했습니다. 네트워크 연결을 확인해주세요.",
        });
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  }
</script>

<style>
  .site-contact {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
    padding: clamp(var(--space-3xl), 7vw, var(--space-4xl)) var(--site-gutter)
      clamp(var(--space-4xl), 8vw, var(--space-5xl));
  }

  .site-contact__hero {
    margin-bottom: clamp(var(--space-2xl), 4vw, var(--space-3xl));
  }

  .site-contact__meta {
    max-width: 44rem;
  }

  .site-contact__grid {
    display: grid;
    gap: clamp(var(--space-xl), 4vw, var(--space-2xl));
  }

  .site-contact__form-card,
  .site-contact__profile-card {
    position: relative;
    overflow: hidden;
  }

  .site-contact__form-card {
    padding: clamp(var(--space-xl), 4vw, var(--space-2xl));
    gap: var(--space-xl);
    border-color: var(--site-border-default);
    background: var(--site-surface-default);
    box-shadow: var(--site-shadow-flat);
  }

  .site-contact__form-header,
  .site-contact__form,
  .site-contact__feedback,
  .site-contact__profile-card > * {
    position: relative;
    z-index: 1;
  }

  .site-contact__form-header {
    margin-bottom: 0;
  }

  .site-contact__form-eyebrow {
    color: var(--color-primary);
  }

  .site-contact__form {
    display: grid;
    gap: var(--space-lg);
  }

  .site-contact__field {
    position: relative;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-md) calc(var(--space-sm) + var(--space-xs));
    border: 1px solid var(--site-border-default);
    border-radius: var(--radius-lg);
    background: var(--site-surface-default);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .site-contact__field::after {
    display: none;
  }

  .site-contact__field:hover {
    border-color: var(--color-text-muted);
  }

  .site-contact__field:focus-within {
    border-color: var(--color-primary);
    box-shadow: var(--site-shadow-focus);
  }

  .site-contact__field .site-form-field__label {
    transition: color var(--transition-fast);
  }

  .site-contact__field:focus-within .site-form-field__label {
    color: var(--color-primary);
  }

  .site-contact__field .site-form-field__control {
    padding: 0 0 var(--space-xs);
    border: none;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }

  .site-contact__field .site-form-field__control:focus-visible {
    border-color: transparent;
    box-shadow: none;
  }

  .site-contact__submit {
    margin-top: var(--space-2xs);
  }

  .site-contact__feedback {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-md);
    align-items: center;
    margin-top: var(--space-xs);
    padding: var(--space-md) var(--space-lg);
    border: 1px solid var(--site-border-default);
    border-radius: var(--radius-lg);
    background: var(--site-surface-default);
  }

  .site-contact__feedback:not([hidden]) {
    animation: site-contact-feedback-enter 360ms ease-out both;
  }

  .site-contact__feedback[data-state="success"] {
    border-color: var(--color-secondary);
    background: var(--site-surface-default);
  }

  .site-contact__feedback[data-state="error"] {
    border-color: var(--color-accent);
    background: var(--site-surface-default);
  }

  .site-contact__feedback-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--site-surface-muted);
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  .site-contact__feedback[data-state="success"] .site-contact__feedback-icon {
    color: var(--color-secondary);
  }

  .site-contact__feedback[data-state="error"] .site-contact__feedback-icon {
    color: var(--color-accent);
  }

  .site-contact__feedback-symbol {
    display: none;
    width: 1.2rem;
    height: 1.2rem;
  }

  .site-contact__feedback[data-state="success"] .site-contact__feedback-symbol--success,
  .site-contact__feedback[data-state="error"] .site-contact__feedback-symbol--error {
    display: block;
  }

  .site-contact__feedback-copy {
    display: grid;
    gap: var(--space-2xs);
  }

  .site-contact__feedback-title,
  .site-contact__feedback-text,
  .site-contact__profile-kicker,
  .site-contact__profile-name,
  .site-contact__profile-title,
  .site-contact__profile-copy,
  .site-contact__social-title,
  .site-contact__social-meta,
  .site-contact__social-action {
    margin: 0;
  }

  .site-contact__feedback-title {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-contact__feedback-text {
    font-size: var(--text-sm);
    line-height: var(--line-height-body);
    color: var(--color-text);
  }

  .site-contact__sidebar {
    display: grid;
    gap: var(--space-lg);
  }

  .site-contact__profile-card {
    padding: clamp(var(--space-xl), 4vw, var(--space-2xl));
    gap: var(--space-lg);
    border-color: var(--site-border-default);
    background: var(--site-surface-elevated);
    box-shadow: var(--site-shadow-flat);
  }

  .site-contact__profile-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .site-contact__profile-kicker {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-contact__profile-header {
    display: grid;
    gap: var(--space-xs);
  }

  .site-contact__profile-name {
    font-size: clamp(var(--text-2xl), 2vw + 1rem, var(--text-3xl));
    line-height: var(--line-height-tight);
    color: var(--color-ink);
  }

  .site-contact__profile-title {
    font-size: var(--text-lg);
    line-height: 1.4;
    color: var(--color-primary);
  }

  .site-contact__profile-copy {
    font-size: var(--text-sm);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
  }

  .site-contact__metadata {
    gap: var(--space-md);
    background: var(--site-surface-muted);
  }

  .site-contact__social-header {
    display: grid;
    gap: var(--space-2xs);
  }

  .site-contact__social-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
  }

  .site-contact__social-meta {
    font-size: var(--text-sm);
    line-height: var(--line-height-body);
    color: var(--color-text-muted);
  }

  .site-contact__social {
    display: grid;
    gap: var(--space-sm);
  }

  .site-contact__social-link {
    justify-content: space-between;
    width: 100%;
    padding-inline: var(--space-md);
    background: var(--site-surface-default);
  }

  .site-contact__social-main {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .site-contact__social-action {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-contact__social-link--github:hover {
    color: var(--color-primary);
  }

  .site-contact__social-link--linkedin:hover {
    color: var(--color-secondary);
  }

  @keyframes site-contact-feedback-enter {
    from {
      opacity: 0;
      transform: translate3d(0, 0.65rem, 0);
    }

    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @media (min-width: 768px) {
    .site-contact__grid {
      grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.85fr);
      align-items: start;
    }

    .site-contact__sidebar {
      position: sticky;
      top: calc(var(--site-nav-height) + var(--space-lg));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-contact__field:focus-within {
      transform: none;
    }

    .site-contact__feedback:not([hidden]) {
      animation: none;
    }
  }
</style>
