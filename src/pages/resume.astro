---
import { existsSync } from "node:fs";
import path from "node:path";

import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublicProfile } from "../lib/public-profile";

const profile = getPublicProfile();

function formatDate(value: string): string {
  return value.replaceAll("-", ".");
}

const documents = [
  {
    title: "이력서",
    fileName: "resume-ko.pdf",
    href: "/downloads/resume-ko.pdf",
    description: "핵심 경력, 포지셔닝, 현재 상태를 빠르게 검토할 수 있는 압축본입니다.",
  },
  {
    title: "기술경력서",
    fileName: "technical-career-ko.pdf",
    href: "/downloads/technical-career-ko.pdf",
    description:
      "프로젝트별 Problem, Role, Stack, Outcome 흐름을 중심으로 정리한 상세 경력 문서입니다.",
  },
  {
    title: "자기소개서",
    fileName: "personal-statement-ko.pdf",
    href: "/downloads/personal-statement-ko.pdf",
    description:
      "건설 CM에서 AI/IT로 이어진 전환 배경과 문제 해결 방식을 서사형으로 풀어낸 문서입니다.",
  },
].map((document) => ({
  ...document,
  available: existsSync(
    path.join(process.cwd(), "public", "downloads", document.fileName),
  ),
}));

const availableCount = documents.filter((document) => document.available).length;
const primaryDocument = documents.find((document) => document.available) ?? null;
const asOfDate = formatDate(profile.careerSummary.asOf);

const documentsStatusMessage =
  availableCount === documents.length
    ? "세 문서 모두 최신 PDF로 동기화되어 있습니다."
    : availableCount > 0
      ? "동기화된 문서만 링크를 보여주고, 준비 중인 문서는 상태로 안내합니다."
      : "현재 웹 다운로드용 PDF를 준비 중입니다. 빌드가 끝나면 링크가 나타납니다.";

const highlightTiles = [
  {
    id: "total-career",
    label: "총 경력",
    value: profile.careerSummary.totalCareer.label,
    detail: "현장 운영과 시스템 설계를 한 흐름으로 압축했습니다.",
    badge: "Career",
    badgeClass: "site-badge site-badge--neutral",
    tone: "secondary",
  },
  {
    id: "construction-cm",
    label: "건설 CM",
    value: profile.careerSummary.constructionCm.label,
    detail: "일정, 문서, 이해관계자 맥락을 읽는 기반 경험입니다.",
    badge: "Construction",
    badgeClass: "site-badge site-badge--domain-construction",
    tone: "accent",
  },
  {
    id: "ai-it",
    label: "AI / IT",
    value: profile.careerSummary.aiIt.label,
    detail: "업무 맥락을 에이전트와 자동화 구조로 번역해 왔습니다.",
    badge: "AI / IT",
    badgeClass: "site-badge site-badge--domain-ai",
    tone: "primary",
  },
  {
    id: "documents",
    label: "동기화 문서",
    value: `${availableCount}/${documents.length}`,
    detail:
      availableCount === documents.length
        ? "세 문서를 즉시 내려받을 수 있습니다."
        : availableCount > 0
          ? "가용한 파일만 바로 다운로드할 수 있습니다."
          : "다운로드 파일을 준비 중입니다.",
    badge: "PDF",
    badgeClass: "site-badge site-badge--neutral",
    tone: "primary-soft",
  },
];
---

<BaseLayout
  title="이력서 다운로드 | 김성식"
  description="김성식의 이력서, 기술경력서, 자기소개서 PDF를 상황에 맞게 내려받을 수 있는 페이지입니다."
>
  <section class="site-resume-hero" aria-labelledby="resume-hero-title">
    <div class="site-resume-hero__inner">
      <div class="site-page-hero site-resume-hero__content" data-reveal="slide-up">
        <p class="site-page-hero__eyebrow site-resume-hero__eyebrow">
          Resume & Downloads
        </p>
        <div class="site-section-header__rule" aria-hidden="true"></div>
        <h1 id="resume-hero-title" class="site-page-hero__title site-resume-hero__title">
          경력의 요점을 먼저 훑고, 필요한 PDF만 바로 꺼낼 수 있게 정리했습니다.
        </h1>
        <p class="site-page-hero__lead site-resume-hero__lead">
          {profile.profile.name.ko} · {profile.profile.positioningTitle}.{" "}
          {profile.currentStatus.display} 기준으로 공개 가능한 문서를 추려 두었고,
          다운로드가 가능한 파일만 바로 연결합니다.
        </p>
        <p class="site-page-hero__meta site-resume-hero__meta">
          업데이트 기준 {asOfDate} · 다운로드 가능 {availableCount}/{documents.length}
          개
        </p>

        <div class="site-resume-hero__actions">
          {primaryDocument ? (
            <a
              href={primaryDocument.href}
              download
              class="site-button site-button--primary site-button--glow"
            >
              {primaryDocument.title} PDF 받기
            </a>
          ) : (
            <a href="/contact" class="site-button site-button--primary site-button--glow">
              문서 문의하기
            </a>
          )}
          <a href="#resume-documents" class="site-button site-button--ghost">
            문서 구성 보기
          </a>
        </div>
      </div>

      <aside class="site-card site-resume-hero__panel" data-reveal="slide-in-left">
        <div class="site-resume-hero__panel-header">
          <span class="site-badge site-badge--state">{profile.currentStatus.label}</span>
          <p class="site-resume-hero__panel-kicker">Download Package</p>
          <h2 class="site-resume-hero__panel-title">
            상황에 맞는 문서를 빠르게 고를 수 있는 PDF 패키지
          </h2>
          <p class="site-resume-hero__panel-copy">{documentsStatusMessage}</p>
        </div>

        <ul class="site-resume-hero__panel-list stagger-children" data-reveal="stagger-children">
          {
            documents.map((document) => (
              <li class="site-resume-hero__panel-item">
                <span class="site-resume-hero__panel-item-icon" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"></path>
                    <path d="M14 2v5h5"></path>
                    <path d="M9 13h6"></path>
                    <path d="M9 17h6"></path>
                  </svg>
                </span>
                <div class="site-resume-hero__panel-item-copy">
                  <strong>{document.title}</strong>
                  <span>{document.fileName}</span>
                </div>
                <span
                  class:list={[
                    "site-badge",
                    document.available
                      ? "site-badge--state"
                      : "site-badge--neutral",
                  ]}
                >
                  {document.available ? "다운로드 가능" : "준비 중"}
                </span>
              </li>
            ))
          }
        </ul>

        <dl class="site-metadata-block site-resume-hero__metadata">
          <div class="site-metadata-block__item">
            <dt>포지셔닝</dt>
            <dd>{profile.profile.positioningTitle}</dd>
          </div>
          <div class="site-metadata-block__item">
            <dt>업데이트</dt>
            <dd>{asOfDate}</dd>
          </div>
          <div class="site-metadata-block__item">
            <dt>다운로드</dt>
            <dd>
              {availableCount}/{documents.length} 문서
            </dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="site-resume-section" aria-labelledby="resume-highlights-title">
    <div class="site-resume-section__inner">
      <header class="site-section-header site-resume-section__header" data-reveal="slide-up">
        <p class="site-section-header__eyebrow">Resume Snapshot</p>
        <div class="site-section-header__rule" aria-hidden="true"></div>
        <h2 id="resume-highlights-title" class="site-section-header__title">
          포지셔닝과 경력 축을 한 화면에서 먼저 훑을 수 있습니다.
        </h2>
        <p class="site-section-header__lead">
          채용 담당자가 PDF를 열기 전에 현재 상태, 경력의 무게중심, 다운로드
          준비 상태를 빠르게 스캔할 수 있게 정리했습니다.
        </p>
      </header>

      <div class="site-resume-bento stagger-children" data-reveal="stagger-children">
        <article class="site-card site-resume-bento__featured">
          <div class="site-resume-bento__featured-head">
            <span class="site-badge site-badge--state">{profile.currentStatus.label}</span>
            <p class="site-resume-bento__featured-kicker">Positioning</p>
          </div>
          <h3 class="site-resume-bento__featured-title">
            {profile.profile.positioningTitle}
          </h3>
          <p class="site-resume-bento__featured-copy">
            건설 CM에서 익힌 현장 해석력과 이해관계자 조율 경험을, AI 협업
            시스템과 자동화 설계로 이어가고 있습니다.
          </p>
          <p class="site-resume-bento__featured-note">
            {profile.currentStatus.display}
          </p>
        </article>

        {
          highlightTiles.map((item) => (
            <article
              class:list={[
                "site-card",
                "site-resume-highlight",
                `site-resume-highlight--${item.tone}`,
              ]}
            >
              <div class="site-resume-highlight__head">
                <span class="site-resume-highlight__icon" aria-hidden="true">
                  {item.id === "total-career" && (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M12 8v5l3 2"></path>
                      <circle cx="12" cy="12" r="9"></circle>
                    </svg>
                  )}
                  {item.id === "construction-cm" && (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M3 21h18"></path>
                      <path d="M5 21V11l7-4 7 4v10"></path>
                      <path d="M9 21v-5h6v5"></path>
                    </svg>
                  )}
                  {item.id === "ai-it" && (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect x="7" y="7" width="10" height="10" rx="2"></rect>
                      <path d="M12 3v4"></path>
                      <path d="M12 17v4"></path>
                      <path d="M3 12h4"></path>
                      <path d="M17 12h4"></path>
                    </svg>
                  )}
                  {item.id === "documents" && (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"></path>
                      <path d="M14 2v5h5"></path>
                      <path d="M9 13h6"></path>
                      <path d="M9 17h4"></path>
                    </svg>
                  )}
                </span>
                <span class={item.badgeClass}>{item.badge}</span>
              </div>
              <div class="site-resume-highlight__body">
                <p class="site-resume-highlight__label">{item.label}</p>
                <p class="site-resume-highlight__value">{item.value}</p>
                <p class="site-resume-highlight__detail">{item.detail}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section
    id="resume-documents"
    class="site-resume-section site-resume-section--documents"
    aria-labelledby="resume-documents-title"
  >
    <div class="site-resume-section__inner">
      <header class="site-section-header site-resume-section__header" data-reveal="slide-up">
        <p class="site-section-header__eyebrow">PDF Documents</p>
        <div class="site-section-header__rule" aria-hidden="true"></div>
        <h2 id="resume-documents-title" class="site-section-header__title">
          목적에 맞게 고를 수 있는 다운로드 카드
        </h2>
        <p class="site-section-header__meta">{documentsStatusMessage}</p>
      </header>

      <div class="site-resume-documents stagger-children" data-reveal="stagger-children">
        {
          documents.map((document) => (
            <article
              class:list={[
                "site-card",
                "site-resume-document",
                document.available && "site-card--interactive",
                document.available && "site-resume-document--available",
              ]}
            >
              <div class="site-resume-document__head">
                <div class="site-resume-document__icon" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"></path>
                    <path d="M14 2v5h5"></path>
                    <path d="M12 18v-6"></path>
                    <path d="m9 15 3 3 3-3"></path>
                  </svg>
                </div>
                <div class="site-resume-document__meta">
                  <p class="site-resume-document__file">{document.fileName}</p>
                  <span
                    class:list={[
                      "site-badge",
                      document.available
                        ? "site-badge--state"
                        : "site-badge--neutral",
                    ]}
                  >
                    {document.available ? "다운로드 가능" : "준비 중"}
                  </span>
                </div>
              </div>

              <div class="site-resume-document__body">
                <h3>{document.title}</h3>
                <p>{document.description}</p>
              </div>

              <div class="site-resume-document__footer">
                {document.available ? (
                  <a
                    class="site-button site-button--primary site-button--full site-resume-document__link"
                    href={document.href}
                    download
                  >
                    PDF 다운로드
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M5 12h14"></path>
                      <path d="m12 5 7 7-7 7"></path>
                    </svg>
                  </a>
                ) : (
                  <p class="site-resume-document__note">
                    현재 내려받을 수 있는 파일이 없어 링크를 숨겼습니다.
                  </p>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="site-resume-section site-resume-section--details" aria-labelledby="resume-details-title">
    <div class="site-resume-section__inner">
      <header class="site-section-header site-resume-section__header" data-reveal="slide-up">
        <p class="site-section-header__eyebrow">Profile Snapshot</p>
        <div class="site-section-header__rule" aria-hidden="true"></div>
        <h2 id="resume-details-title" class="site-section-header__title">
          PDF를 열기 전에 확인할 수 있는 핵심 이력 스냅샷
        </h2>
        <p class="site-section-header__meta">
          학력, 자격, 온라인 프로필을 공개 범위 안에서만 요약해 두었습니다.
        </p>
      </header>

      <div class="site-resume-panels stagger-children" data-reveal="stagger-children">
        <section class="site-card site-resume-panel site-resume-panel--education">
          <div class="site-resume-panel__header">
            <span class="site-resume-panel__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m22 10-10-5-10 5 10 5 10-5z"></path>
                <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
              </svg>
            </span>
            <div>
              <p class="site-resume-panel__eyebrow">Education</p>
              <h3>학력</h3>
            </div>
          </div>
          <ul>
            {
              profile.education.map((education) => (
                <li>
                  <strong>{education.degree}</strong>
                  <span>{education.institution}</span>
                  <span>{education.department}</span>
                  <span>{education.period.display}</span>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="site-card site-resume-panel site-resume-panel--certifications">
          <div class="site-resume-panel__header">
            <span class="site-resume-panel__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M12 15 8.5 17l1-4-3-2.6 4-.4L12 6l1.5 4 4 .4-3 2.6 1 4z"></path>
              </svg>
            </span>
            <div>
              <p class="site-resume-panel__eyebrow">Credentials</p>
              <h3>자격 및 이수</h3>
            </div>
          </div>
          <ul>
            {
              profile.certifications.map((certification) => (
                <li>
                  <strong>{certification.name}</strong>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="site-card site-resume-panel site-resume-panel--profiles">
          <div class="site-resume-panel__header">
            <span class="site-resume-panel__icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect width="4" height="12" x="2" y="9"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </span>
            <div>
              <p class="site-resume-panel__eyebrow">Profiles</p>
              <h3>온라인 프로필</h3>
            </div>
          </div>
          <ul class="site-resume-links">
            <li>
              <a
                href={profile.profile.contacts.github.url}
                target="_blank"
                rel="noreferrer"
              >
                GitHub · {profile.profile.contacts.github.username}
              </a>
            </li>
            <li>
              <a
                href={profile.profile.contacts.linkedin.url}
                target="_blank"
                rel="noreferrer"
              >
                LinkedIn 프로필 보기
              </a>
            </li>
          </ul>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .site-resume-hero {
    position: relative;
    overflow: hidden;
    padding:
      clamp(var(--space-4xl), 9vw, 6.5rem) var(--site-gutter)
      clamp(var(--space-3xl), 7vw, var(--space-5xl));
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 4%, var(--color-paper)),
      color-mix(in srgb, var(--site-surface-muted) 72%, var(--color-paper))
    );
    border-bottom: 1px solid
      color-mix(in srgb, var(--site-border-default) 72%, var(--color-primary) 28%);
  }

  .site-resume-hero::before,
  .site-resume-hero::after {
    display: none;
  }

  .site-resume-hero__inner,
  .site-resume-section__inner {
    position: relative;
    z-index: 1;
    max-width: var(--site-content-max-width);
    margin: 0 auto;
  }

  .site-resume-hero__inner {
    display: grid;
    gap: clamp(var(--space-xl), 4vw, var(--space-3xl));
    align-items: start;
  }

  .site-resume-hero__content {
    margin-bottom: 0;
    align-content: start;
  }

  .site-resume-hero__eyebrow {
    color: var(--color-primary);
  }

  .site-resume-hero__title {
    max-width: 11ch;
    font-size: clamp(var(--text-4xl), 7vw, var(--text-7xl));
    line-height: 0.94;
    letter-spacing: -0.06em;
  }

  .site-resume-hero__lead {
    max-width: 36rem;
  }

  .site-resume-hero__meta {
    color: var(--color-text-secondary);
  }

  .site-resume-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .site-resume-hero__panel {
    position: relative;
    overflow: hidden;
    gap: var(--space-lg);
    padding: clamp(var(--space-lg), 3vw, var(--space-2xl));
    border-color: color-mix(
      in srgb,
      var(--site-border-default) 84%,
      var(--color-secondary) 16%
    );
    background: var(--site-surface-default);
    box-shadow: var(--site-shadow-raised);
  }

  .site-resume-hero__panel::before {
    display: none;
  }

  .site-resume-hero__panel-header,
  .site-resume-hero__panel-list,
  .site-resume-hero__metadata {
    position: relative;
    z-index: 1;
  }

  .site-resume-hero__panel-kicker,
  .site-resume-bento__featured-kicker,
  .site-resume-highlight__label,
  .site-resume-panel__eyebrow,
  .site-resume-document__file {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
