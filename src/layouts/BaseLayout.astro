---
import { ClientRouter } from "astro:transitions";
import "../styles/site.css";
import SeoHead from "../components/SeoHead.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import type { StructuredDataInput } from "../lib/structured-data";
import { withBase } from "../lib/site";

interface Props {
  lang?: string;
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  structuredData?: StructuredDataInput;
}

const {
  lang = Astro.currentLocale ?? "ko",
  title,
  description,
  ogImage,
  ogType,
  noindex,
  structuredData,
} = Astro.props;

const preloadFonts = [
  withBase("/fonts/pretendard-regular-subset.woff2"),
  withBase("/fonts/pretendard-semibold-subset.woff2"),
];
const faviconHref =
  "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='16' fill='%231d4ed8'/%3E%3Ctext x='50%25' y='54%25' text-anchor='middle' dominant-baseline='middle' font-family='Pretendard,Arial,sans-serif' font-size='28' font-weight='700' fill='white'%3EKS%3C/text%3E%3C/svg%3E";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <ClientRouter />
    {
      preloadFonts.map((href) => (
        <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
      ))
    }
    <SeoHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      structuredData={structuredData}
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">본문으로 건너뛰기</a>
    <SiteHeader />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
    <script>
      import "../scripts/reveal.ts";
    </script>
  </body>
</html>

<style is:global>
  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--site-gutter);
    z-index: 200;
    padding: var(--space-xs) var(--space-md);
    background: var(--color-primary);
    color: var(--color-paper);
    text-decoration: none;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
  }

  .skip-link:focus-visible {
    top: var(--space-xs);
  }
</style>
