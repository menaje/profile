---
import type { PublicProfile, PublicCurrentStatus } from "../lib/public-profile";

interface Props {
  profile: PublicProfile;
  currentStatus: PublicCurrentStatus;
}

const { profile, currentStatus } = Astro.props;
const { github, linkedin } = profile.contacts;
---

<section class="site-cta" aria-labelledby="cta-heading">
  <div class="site-cta__inner">
    <h2 id="cta-heading" class="site-cta__title">함께 일해보고 싶으신가요?</h2>
    <p class="site-cta__text">
      {
        currentStatus.employmentState === "seeking"
          ? "현재 새로운 기회를 찾고 있습니다. 프로젝트나 역할에 대해 편하게 연락주세요."
          : "프로젝트나 협업에 대해 편하게 연락주세요."
      }
    </p>
    <div class="site-cta__actions">
      <a href="/contact" class="site-cta__button site-button site-button--primary">
        연락하기
      </a>
      <div class="site-cta__links">
        <a
          href={github.url}
          target="_blank"
          rel="noopener noreferrer"
          class="site-cta__link site-button site-button--ghost site-button--quiet"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
          GitHub
        </a>
        <a
          href={linkedin.url}
          target="_blank"
          rel="noopener noreferrer"
          class="site-cta__link site-button site-button--ghost site-button--quiet"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .site-cta {
    padding: var(--space-5xl) var(--site-gutter);
    text-align: center;
  }

  .site-cta__inner {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .site-cta__title {
    font-size: var(--text-2xl);
    color: var(--color-ink);
    margin: 0;
  }

  .site-cta__text {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    max-width: 48ch;
    margin: 0;
  }

  .site-cta__actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    margin-top: var(--space-md);
  }

  .site-cta__links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
  }

  .site-cta__link {
    font-size: var(--text-sm);
  }

  @media (min-width: 768px) {
    .site-cta__title {
      font-size: var(--text-3xl);
    }
  }
</style>
