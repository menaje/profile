---
import type { PublicProfile, PublicCurrentStatus } from "../lib/public-profile";
import { withBase } from "../lib/site";

interface Props {
  profile: PublicProfile;
  currentStatus: PublicCurrentStatus;
}

const { profile, currentStatus } = Astro.props;

const bridgeDomains = [
  {
    id: "cm",
    badgeClass: "site-badge--domain-construction",
    label: "건설CM",
    title: "현장 문제 해석",
    items: ["현장 맥락", "이해관계자 조율", "리스크 판단"],
  },
  {
    id: "ai",
    badgeClass: "site-badge--domain-ai",
    label: "AI / IT",
    title: "협업 시스템 설계",
    items: ["자동화 흐름", "협업 인터페이스", "시스템 구조화"],
  },
];
---

<section class="site-hero" aria-labelledby="hero-heading">
  <div class="site-hero__inner">
    <div class="site-hero__content site-page-hero">
      <p class="site-page-hero__eyebrow">{profile.positioningTitle}</p>
      <div class="site-section-header__rule site-hero__rule" aria-hidden="true"></div>
      <div class="site-hero__title-group">
        <p class="site-hero__headline">건설 현장의 언어를 읽고</p>
        <h1 id="hero-heading" class="site-page-hero__title site-hero__name">
          {profile.name.ko}
        </h1>
        <p class="site-hero__headline site-hero__headline--accent">AI 협업 시스템으로 번역합니다</p>
      </div>
      <p class="site-page-hero__lead site-hero__lead">
        도메인 맥락, 문서 흐름, 이해관계자의 요구를 읽고 실제 업무가 굴러가는 협업 구조와 자동화
        가능한 시스템으로 연결합니다.
      </p>
      <div class="site-hero__status-inline">
        <span class="site-badge site-badge--state">{currentStatus.label}</span>
      </div>
      <div class="site-hero__actions">
        <a href={withBase("/projects/")} class="site-hero__link site-button site-button--ghost">
          프로젝트 보기
        </a>
      </div>
    </div>

    <div class="site-hero__visual">
      <p class="site-hero__sr-only">
        건설CM 경험과 AI 협업 시스템 설계를 연결하는 도메인 브릿지 비주얼
      </p>
      <div class="site-card site-hero__visual-frame">
        <svg
          class="site-hero__diagram"
          viewBox="0 0 480 400"
          fill="none"
          aria-hidden="true"
          role="presentation"
        >
          <path
            class="site-hero__diagram-line site-hero__diagram-line--cm"
            d="M110 100C160 120 200 170 234 240"></path>
          <path
            class="site-hero__diagram-line site-hero__diagram-line--ai"
            d="M380 120C330 140 280 190 250 240"></path>
          <path class="site-hero__diagram-line site-hero__diagram-line--bridge" d="M240 270V330"
          ></path>
          <circle
            class="site-hero__diagram-point site-hero__diagram-point--cm"
            cx="110"
            cy="100"
            r="10"></circle>
          <circle
            class="site-hero__diagram-point site-hero__diagram-point--hub"
            cx="240"
            cy="250"
            r="16"></circle>
          <circle
            class="site-hero__diagram-point site-hero__diagram-point--ai"
            cx="380"
            cy="120"
            r="10"></circle>
          <circle
            class="site-hero__diagram-point site-hero__diagram-point--status"
            cx="240"
            cy="330"
            r="10"></circle>
        </svg>

        {
          bridgeDomains.map((domain) => (
            <div
              class:list={[
                "site-card",
                "site-hero__domain-card",
                `site-hero__domain-card--${domain.id}`,
              ]}
            >
              <span class:list={["site-badge", domain.badgeClass]}>{domain.label}</span>
              <p class="site-hero__domain-title">{domain.title}</p>
              <ul class="site-hero__domain-list">
                {domain.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))
        }

        <div class="site-hero__hub">
          <p class="site-hero__hub-label">도메인 브릿지</p>
          <p class="site-hero__hub-title">문제 번역</p>
          <p class="site-hero__hub-copy">
            현장 언어를
            <br />
            협업 시스템 구조로 연결
          </p>
        </div>

        <div class="site-card site-hero__status-panel">
          <div class="site-hero__status-panel-header">
            <span class="site-badge site-badge--state">
              {currentStatus.label}
            </span>
            <p class="site-hero__status-kicker">현재 포지셔닝</p>
          </div>
          <p class="site-hero__status-title">{profile.positioningTitle}</p>
          <p class="site-hero__status-text">{currentStatus.display}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .site-hero {
    padding: clamp(var(--space-4xl), 8vw, 6.5rem) var(--site-gutter)
      clamp(var(--space-4xl), 7vw, var(--space-5xl));
  }

  .site-hero__inner {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
    display: grid;
    gap: clamp(var(--space-2xl), 6vw, 4.5rem);
    align-items: center;
  }

  .site-hero__content {
    margin-bottom: 0;
    align-content: center;
  }

  .site-hero__rule {
    margin: 0;
  }

  .site-hero__title-group {
    display: grid;
    gap: var(--space-sm);
  }

  .site-hero__headline {
    margin: 0;
    font-size: clamp(var(--text-xl), 1rem + 2vw, var(--text-3xl));
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-text-secondary);
  }

  .site-hero__headline--accent {
    color: var(--color-primary);
  }

  .site-hero__name {
    font-size: var(--text-7xl);
    line-height: 0.9;
    letter-spacing: -0.06em;
    margin: 0;
  }

  .site-hero__lead {
    max-width: 35rem;
    margin: 0;
  }

  .site-hero__status-inline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
  }

  .site-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .site-hero__visual {
    position: relative;
  }

  .site-hero__visual-frame {
    position: relative;
    isolation: isolate;
    display: grid;
    gap: var(--space-md);
    min-height: 0;
    padding: clamp(var(--space-lg), 3vw, var(--space-xl));
    overflow: hidden;
    border-color: var(--site-border-default);
    background: var(--site-surface-muted);
    box-shadow: var(--site-shadow-flat);
  }

  .site-hero__diagram {
    display: none;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.68;
    pointer-events: none;
  }

  .site-hero__diagram-line {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.5;
  }

  .site-hero__diagram-line--cm {
    stroke: var(--color-accent);
  }

  .site-hero__diagram-line--ai {
    stroke: var(--color-primary);
  }

  .site-hero__diagram-line--bridge {
    stroke: var(--color-accent);
  }

  .site-hero__diagram-point {
    stroke-width: 2;
  }

  .site-hero__diagram-point--cm {
    fill: var(--color-paper);
    stroke: var(--color-accent);
  }

  .site-hero__diagram-point--hub {
    fill: var(--color-paper);
    stroke: var(--color-accent);
  }

  .site-hero__diagram-point--ai {
    fill: var(--color-paper);
    stroke: var(--color-primary);
  }

  .site-hero__diagram-point--status {
    fill: var(--color-paper);
    stroke: var(--color-accent);
  }

  .site-hero__domain-card,
  .site-hero__status-panel,
  .site-hero__hub {
    position: relative;
    z-index: 1;
  }

  .site-hero__domain-card {
    --site-hero-accent: var(--color-primary);
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--color-paper);
    border-color: var(--site-border-default);
    box-shadow: var(--site-shadow-flat);
  }

  .site-hero__domain-card--cm {
    --site-hero-accent: var(--color-accent);
  }

  .site-hero__domain-card--ai {
    --site-hero-accent: var(--color-primary);
  }

  .site-hero__domain-title {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-ink);
  }

  .site-hero__domain-list {
    display: grid;
    gap: var(--space-xs);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-hero__domain-list li {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .site-hero__domain-list li::before {
    content: "";
    inline-size: 0.45rem;
    block-size: 0.45rem;
    border-radius: 50%;
    background: var(--site-hero-accent);
    flex: none;
  }

  .site-hero__hub {
    justify-self: center;
    display: grid;
    gap: var(--space-2xs);
    max-width: 15rem;
    padding: var(--space-lg);
    border: 1px solid var(--site-border-default);
    border-radius: calc(var(--radius-xl) * 1.35);
    background: var(--color-paper);
    box-shadow: var(--site-shadow-flat);
    text-align: center;
  }

  .site-hero__hub-label {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-hero__hub-title {
    margin: 0;
    font-size: clamp(var(--text-xl), 1rem + 1.2vw, var(--text-2xl));
    font-weight: 700;
    line-height: 1;
    color: var(--color-ink);
  }

  .site-hero__hub-copy {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.45;
    color: var(--color-text-secondary);
  }

  .site-hero__status-panel {
    gap: var(--space-sm);
    border-color: var(--site-border-default);
    background: var(--color-paper);
  }

  .site-hero__status-panel-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .site-hero__status-kicker {
    margin: 0;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-hero__status-title {
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-ink);
  }

  .site-hero__status-text {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
  }

  .site-hero__sr-only {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 768px) {
    .site-hero__visual-frame {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }

    .site-hero__diagram {
      display: block;
    }

    .site-hero__hub,
    .site-hero__status-panel {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .site-hero__inner {
      grid-template-columns: minmax(0, 1.22fr) minmax(0, 1fr);
    }

    .site-hero__visual-frame {
      min-height: 30rem;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      grid-template-rows: repeat(12, minmax(0, 1fr));
    }

    .site-hero__domain-card--cm {
      grid-column: 1 / 7;
      grid-row: 1 / 5;
    }

    .site-hero__domain-card--ai {
      grid-column: 7 / -1;
      grid-row: 2 / 6;
    }

    .site-hero__hub {
      grid-column: 3 / 11;
      grid-row: 6 / 9;
      align-self: center;
    }

    .site-hero__status-panel {
      grid-column: 2 / 12;
      grid-row: 10 / -1;
      align-self: end;
    }
  }
</style>
