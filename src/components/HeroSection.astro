---
import type { PublicProfile, PublicCurrentStatus } from "../lib/public-profile";

interface Props {
  profile: PublicProfile;
  currentStatus: PublicCurrentStatus;
}

const { profile, currentStatus } = Astro.props;
---

<section class="site-hero" aria-labelledby="hero-heading">
  <div class="site-hero__inner">
    <span class="eyebrow">{profile.positioningTitle}</span>
    <div class="accent-rule"></div>
    <h1 id="hero-heading" class="site-hero__name">{profile.name.ko}</h1>
    <p class="site-hero__tagline">
      건설 현장의 실제 문제를 AI 협업 시스템으로 번역하는<br
        aria-hidden="true"
      />시스템 아키텍트입니다.
    </p>
    {
      currentStatus.employmentState === "seeking" && (
        <span class="status-chip site-hero__status">{currentStatus.label}</span>
      )
    }
    <div class="site-hero__actions">
      <a href="/contact" class="site-hero__cta">연락하기</a>
      <a href="/projects" class="site-hero__link">프로젝트 보기</a>
    </div>
  </div>
</section>

<style>
  .site-hero {
    padding: var(--space-5xl) var(--site-gutter) var(--space-4xl);
  }

  .site-hero__inner {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .site-hero__name {
    font-size: var(--text-3xl);
    line-height: var(--line-height-tight);
    color: var(--color-ink);
    margin: 0;
  }

  .site-hero__tagline {
    font-size: var(--text-lg);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
    max-width: 48ch;
    margin: 0;
  }

  .site-hero__status {
    margin-top: var(--space-2xs);
  }

  .site-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .site-hero__cta {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-xl);
    background: var(--color-primary);
    color: var(--color-paper);
    text-decoration: none;
    font-weight: 600;
    font-size: var(--text-md);
    border-radius: var(--radius-md);
    transition:
      background var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-hero__cta:hover {
    background: var(--color-ink);
    transform: var(--hover-lift);
  }

  .site-hero__link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-md);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .site-hero__link:hover {
    color: var(--color-primary);
  }

  @media (min-width: 768px) {
    .site-hero {
      padding: var(--space-5xl) var(--site-gutter);
    }

    .site-hero__name {
      font-size: var(--text-4xl);
    }

    .site-hero__tagline {
      font-size: var(--text-xl);
    }
  }

  @media (min-width: 1024px) {
    .site-hero__name {
      font-size: var(--text-5xl);
    }
  }
</style>
