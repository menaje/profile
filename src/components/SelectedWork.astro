---
import type { PublicProject, PublicOrganization } from "../lib/public-profile";

interface Props {
  projects: PublicProject[];
  organizations: PublicOrganization[];
}

const { projects, organizations } = Astro.props;

function getOrgName(orgId: string | null): string {
  if (!orgId) return "개인 프로젝트";
  const org = organizations.find((o) => o.id === orgId);
  return org?.displayName ?? "—";
}

function classificationLabel(classification: string): string {
  switch (classification) {
    case "personal":
      return "개인";
    case "company":
      return "회사";
    case "open-source":
      return "오픈소스";
    default:
      return classification;
  }
}
---

<section class="site-work" aria-labelledby="work-heading">
  <div class="site-work__inner">
    <div class="site-work__header site-section-header">
      <div class="site-section-header__rule" aria-hidden="true"></div>
      <h2 id="work-heading" class="site-work__title site-section-header__title">
        대표 프로젝트
      </h2>
      <p class="site-work__lead site-section-header__lead">
        건설 현장과 AI 기술을 잇는 시스템을 기획하고 만들었습니다.
      </p>
    </div>

    <div class="site-work__grid">
      {
        projects.map((project) => (
          <article class="site-work__card site-card site-card--interactive">
            <div class="site-work__card-head">
              <span class="site-badge site-badge--primary">
                {classificationLabel(project.classification)}
              </span>
              {project.statusAtBasisDate === "ongoing" && (
                <span class="site-badge site-badge--accent">진행 중</span>
              )}
            </div>
            <h3 class="site-work__card-name">{project.canonicalName}</h3>
            <p class="site-work__card-role">{project.role}</p>
            <div class="site-work__card-meta">
              <span class="site-work__card-org">
                {getOrgName(project.organizationId)}
              </span>
              <span class="site-work__card-period">
                {project.period.display}
              </span>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .site-work {
    padding: var(--space-5xl) var(--site-gutter);
  }

  .site-work__inner {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
  }

  .site-work__grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: 1fr;
  }

  .site-work__card {
    gap: var(--space-sm);
  }

  .site-work__card-head {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xs);
  }

  .site-work__card-name {
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin: 0;
  }

  .site-work__card-role {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .site-work__card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-top: auto;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-line);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .site-work__card-org::after {
    content: "·";
    margin-left: var(--space-sm);
  }

  @media (min-width: 768px) {
    .site-work__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .site-work__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
