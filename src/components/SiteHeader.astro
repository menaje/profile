---
import { withBase } from "../lib/site";
import { useTranslations } from "../lib/translations";
import type { Locale } from "../lib/i18n";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  lang?: Locale;
}

const { lang = (Astro.currentLocale as Locale) ?? "ko" } = Astro.props;
const tr = useTranslations(lang);

const navItems = [
  { label: tr("nav", "about"), href: withBase("/about/") },
  { label: tr("nav", "projects"), href: withBase("/projects/") },
  { label: tr("nav", "resume"), href: withBase("/resume/") },
  { label: tr("nav", "blog"), href: withBase("/blog/") },
];

const currentPath = Astro.url.pathname;
const displayName = lang === "en" ? "Seongsik Kim" : "김성식";
---

<header class="site-header">
  <nav class="site-nav" aria-label={tr("nav", "mainNav")}>
    <div class="site-nav__bar">
      <a href={withBase("/")} class="site-nav__logo">
        <span class="site-nav__logo-mark" aria-hidden="true">KS</span>
        <span class="site-nav__logo-name">{displayName}</span>
        <span class="site-nav__sr-only">{tr("nav", "goHome")}</span>
      </a>

      <div class="site-nav__actions">
        <ThemeToggle lang={lang} />
        <button
          type="button"
          class="site-nav__toggle"
          aria-expanded="false"
          aria-controls="site-nav-menu"
          aria-label={tr("nav", "menuOpen")}
          data-label-open={tr("nav", "menuOpen")}
          data-label-close={tr("nav", "menuClose")}
        >
        <svg
          class="site-nav__icon site-nav__icon--open"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          class="site-nav__icon site-nav__icon--close"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      </div>

      <div id="site-nav-menu" class="site-nav__panel">
        <div class="site-nav__panel-inner">
          <ul class="site-nav__menu">
            {
              navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="site-nav__link"
                    aria-current={
                      currentPath === item.href || currentPath.startsWith(item.href)
                        ? "page"
                        : undefined
                    }
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>(".site-header");
  const toggle = document.querySelector<HTMLButtonElement>(".site-nav__toggle");
  const menu = document.getElementById("site-nav-menu");

  const syncScrollState = () => {
    if (!header) return;
    header.dataset.scrolled = window.scrollY > 0 ? "true" : "false";
  };

  syncScrollState();
  window.addEventListener("scroll", syncScrollState, { passive: true });

  if (toggle && menu instanceof HTMLElement) {
    const setMenuOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      const closeLabel = toggle.dataset.labelClose ?? "메뉴 닫기";
      const openLabel = toggle.dataset.labelOpen ?? "메뉴 열기";
      toggle.setAttribute("aria-label", open ? closeLabel : openLabel);
      menu.classList.toggle("site-nav__panel--open", open);

      if (header) {
        header.dataset.menuOpen = String(open);
      }
    };

    const closeMenu = () => {
      setMenuOpen(false);
    };

    toggle.addEventListener("click", () => {
      const nextOpen = toggle.getAttribute("aria-expanded") !== "true";
      setMenuOpen(nextOpen);
    });

    menu.querySelectorAll<HTMLAnchorElement>("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
      }
    });

    window.addEventListener("resize", () => {
      if (window.matchMedia("(min-width: 768px)").matches) {
        closeMenu();
      }
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: var(--space-sm) var(--site-gutter) 0;
  }

  .site-nav {
    max-width: var(--site-max-width);
    margin: 0 auto;
  }

  .site-nav__actions {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .site-nav__bar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-sm);
    min-height: calc(var(--site-nav-height) + var(--space-sm));
    padding: var(--space-xs);
    border: 1px solid var(--site-border-default);
    border-radius: calc(var(--radius-pill) + var(--space-xs));
    background: var(--color-paper);
    box-shadow: var(--site-shadow-flat);
    transition:
      background var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      backdrop-filter var(--transition-base);
  }

  .site-header[data-scrolled="true"] .site-nav__bar,
  .site-header[data-menu-open="true"] .site-nav__bar {
    border-color: var(--site-border-default);
    background: var(--color-paper);
    box-shadow: var(--site-shadow-flat);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .site-nav__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    min-height: 44px;
    padding-inline: var(--space-xs);
    color: var(--color-ink);
    text-decoration: none;
  }

  .site-nav__logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--site-border-default);
    border-radius: var(--radius-pill);
    background: var(--color-paper);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .site-nav__logo-name {
    font-size: var(--text-md);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .site-nav__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-nav__logo:hover .site-nav__logo-mark,
  .site-nav__logo:focus-visible .site-nav__logo-mark {
    border-color: var(--color-primary);
  }

  .site-nav__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    justify-self: end;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    border: 1px solid var(--site-border-default);
    border-radius: var(--radius-pill);
    background: var(--site-surface-muted);
    cursor: pointer;
    color: var(--color-ink);
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast),
      color var(--transition-fast);
  }

  .site-nav__toggle:hover {
    border-color: var(--site-border-accent);
    background: var(--site-surface-muted);
    color: var(--color-primary);
  }

  .site-nav__icon--close {
    display: none;
  }

  .site-nav__toggle[aria-expanded="true"] .site-nav__icon--open {
    display: none;
  }

  .site-nav__toggle[aria-expanded="true"] .site-nav__icon--close {
    display: block;
  }

  .site-nav__panel {
    grid-column: 1 / -1;
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    visibility: hidden;
    transform: translateY(calc(var(--space-xs) * -1));
    transition:
      grid-template-rows var(--transition-base),
      opacity var(--transition-fast),
      visibility 0s linear var(--transition-fast),
      transform var(--transition-base);
  }

  .site-nav__panel--open {
    grid-template-rows: 1fr;
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition:
      grid-template-rows var(--transition-base),
      opacity var(--transition-fast),
      transform var(--transition-base);
  }

  .site-nav__panel-inner {
    min-height: 0;
    overflow: hidden;
  }

  .site-nav__menu {
    display: grid;
    gap: var(--space-2xs);
    list-style: none;
    margin: 0;
    padding: var(--space-sm) 0 0;
  }

  .site-nav__link {
    display: flex;
    align-items: center;
    position: relative;
    min-height: 44px;
    padding: 0.9rem 1rem;
    border-radius: var(--radius-md);
    background: var(--site-surface-default);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-md);
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
  }

  .site-nav__link::after {
    content: "";
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 0.7rem;
    height: 0.16rem;
    border-radius: var(--radius-pill);
    background: var(--color-primary);
    opacity: 0.24;
    transform: scaleX(0);
    transform-origin: left;
    transition:
      transform var(--transition-base),
      opacity var(--transition-fast);
  }

  .site-nav__link:hover {
    background: var(--site-surface-muted);
    color: var(--color-primary);
  }

  .site-nav__link:hover::after,
  .site-nav__link:focus-visible::after,
  .site-nav__link[aria-current="page"]::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .site-nav__link[aria-current="page"] {
    background: var(--site-surface-muted);
    color: var(--color-ink);
    font-weight: 600;
  }

  @media (min-width: 768px) {
    .site-header {
      padding-top: var(--space-md);
    }

    .site-nav__bar {
      grid-template-columns: auto minmax(0, 1fr) auto;
      padding-inline: var(--space-sm);
    }

    .site-nav__toggle {
      display: none;
    }

    .site-nav__actions {
      order: 3;
    }

    .site-nav__panel {
      grid-column: 2;
      justify-self: end;
      display: block;
      opacity: 1;
      visibility: visible;
      transform: none;
    }

    .site-nav__panel-inner {
      overflow: visible;
    }

    .site-nav__menu {
      display: flex;
      align-items: center;
      gap: var(--space-2xs);
      padding-top: 0;
    }

    .site-nav__link {
      padding: 0.8rem 0.95rem;
      background: transparent;
    }

    .site-nav__link::after {
      left: 0.95rem;
      right: 0.95rem;
      bottom: 0.45rem;
    }
  }
</style>
