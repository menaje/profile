---
import type { PublicCareerSummary } from "../lib/public-profile";

interface Props {
  careerSummary: PublicCareerSummary;
}

const { careerSummary } = Astro.props;

type MetricKey = "total" | "construction" | "ai";

interface MetricCopy {
  key: MetricKey;
  label: string;
  badge: string;
  badgeClass: string;
  value: string;
  supportingValue: string;
  supportingLabel: string;
  detail: string;
  meta: string;
}

interface ParsedMetricValue {
  prefix: string;
  count: number | null;
  suffix: string;
}

function parseMetricValue(label: string): ParsedMetricValue {
  const match = label.match(/\d+/);

  if (!match || match.index === undefined) {
    return {
      prefix: "",
      count: null,
      suffix: label,
    };
  }

  return {
    prefix: label.slice(0, match.index),
    count: Number.parseInt(match[0], 10),
    suffix: label.slice(match.index + match[0].length),
  };
}

function formatDate(value: string): string {
  return value.replaceAll("-", ".");
}

const metrics: MetricCopy[] = [
  {
    key: "total",
    label: "총 경력",
    badge: "Cross-domain",
    badgeClass: "site-badge site-badge--neutral",
    value: careerSummary.totalCareer.label,
    supportingValue: formatDate(careerSummary.totalCareer.start.value),
    supportingLabel: "시작",
    detail: "현장 운영 맥락과 AI 시스템 설계를 한 흐름으로 축적했습니다.",
    meta: `${formatDate(careerSummary.totalCareer.start.value)} 시작 · ${formatDate(careerSummary.asOf)} 기준`,
  },
  {
    key: "construction",
    label: "건설 CM",
    badge: "Construction",
    badgeClass: "site-badge site-badge--domain-construction",
    value: careerSummary.constructionCm.label,
    supportingValue: careerSummary.constructionCm.period.display ?? "기간 미상",
    supportingLabel: "기간",
    detail: "프로세스, 이해관계자, 리스크를 구조화한 도메인 경험입니다.",
    meta: "사업관리 · 원가 · 일정 · 협업 운영",
  },
  {
    key: "ai",
    label: "AI / IT",
    badge: "AI / IT",
    badgeClass: "site-badge site-badge--domain-ai",
    value: careerSummary.aiIt.label,
    supportingValue: careerSummary.aiIt.period.display ?? "기간 미상",
    supportingLabel: "기간",
    detail: "업무 맥락을 에이전트, 자동화, 서비스 구현으로 번역했습니다.",
    meta: "에이전트 설계 · 자동화 · 제품 구현",
  },
];
---

<section class="site-proof" aria-labelledby="proof-heading" data-reveal="slide-up">
  <div class="site-proof__inner">
    <div class="site-proof__header site-section-header">
      <p class="site-section-header__eyebrow">Proof</p>
      <div class="site-section-header__rule" aria-hidden="true"></div>
      <h2 id="proof-heading" class="site-section-header__title">
        숫자로 검증된 경력
      </h2>
      <p class="site-section-header__lead">
        건설 CM에서 AI / IT까지, 도메인 문제를 시스템으로 구조화해 온
        시간을 압축했습니다.
      </p>
    </div>

    <ul class="site-proof__grid" data-proof-grid role="list">
      {
        metrics.map((metric) => {
          const parsed = parseMetricValue(metric.value);
          const countTarget = parsed.count === null ? undefined : String(parsed.count);

          return (
            <li
              class:list={[
                "site-proof__item",
                "site-card",
                "site-card--interactive",
                `site-proof__item--${metric.key}`,
              ]}
            >
              <div class="site-proof__head">
                <span class="site-proof__icon" aria-hidden="true">
                  {metric.key === "total" && (
                    <svg
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M4 12h7"></path>
                      <path d="M13 6h7"></path>
                      <path d="M13 18h7"></path>
                      <path d="M11 5 8 12l3 7"></path>
                    </svg>
                  )}
                  {metric.key === "construction" && (
                    <svg
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M3 21h18"></path>
                      <path d="M5 21V11l7-4 7 4v10"></path>
                      <path d="M9 21v-5h6v5"></path>
                      <path d="M8 7.5V5.5h8v2"></path>
                    </svg>
                  )}
                  {metric.key === "ai" && (
                    <svg
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect x="7" y="7" width="10" height="10" rx="2"></rect>
                      <path d="M12 3v4"></path>
                      <path d="M12 17v4"></path>
                      <path d="M3 12h4"></path>
                      <path d="M17 12h4"></path>
                      <path d="M8.5 8.5h7"></path>
                      <path d="M8.5 12h7"></path>
                      <path d="M8.5 15.5h4"></path>
                    </svg>
                  )}
                </span>
                <span class={metric.badgeClass}>{metric.badge}</span>
              </div>

              <div class="site-proof__content">
                <p class="site-proof__label">{metric.label}</p>
                <p class="site-proof__value" aria-label={metric.value}>
                  {parsed.prefix && (
                    <span class="site-proof__value-prefix">{parsed.prefix}</span>
                  )}
                  {parsed.count !== null ? (
                    <span
                      class="site-proof__value-number"
                      data-counter-target={countTarget}
                    >
                      {parsed.count}
                    </span>
                  ) : (
                    <span class="site-proof__value-number">{metric.value}</span>
                  )}
                  {parsed.suffix && (
                    <span class="site-proof__value-suffix">{parsed.suffix}</span>
                  )}
                </p>
                <p class="site-proof__detail">{metric.detail}</p>
              </div>

              <div class="site-proof__support">
                <span class="site-proof__support-label">
                  {metric.supportingLabel}
                </span>
                <strong class="site-proof__support-value">
                  {metric.supportingValue}
                </strong>
              </div>

              <p class="site-proof__meta">{metric.meta}</p>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>

<script>
  function initProofCounters() {
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>(".site-proof"),
    );

    if (!sections.length) {
      return;
    }

    const prefersReducedMotion = () =>
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const easeOutCubic = (value: number) => 1 - Math.pow(1 - value, 3);

    sections.forEach((section) => {
      const counters = Array.from(
        section.querySelectorAll<HTMLElement>("[data-counter-target]"),
      );

      if (!counters.length || section.dataset.counterBound === "true") {
        return;
      }

      section.dataset.counterBound = "true";

      const finalizeCounter = (counter: HTMLElement) => {
        const target = counter.dataset.counterTarget;

        if (!target) {
          return;
        }

        counter.textContent = target;
        counter.dataset.counterState = "complete";
      };

      const animateCounter = (counter: HTMLElement, delayMs: number) => {
        if (counter.dataset.counterState === "complete") {
          return;
        }

        const target = Number.parseInt(counter.dataset.counterTarget ?? "", 10);

        if (!Number.isFinite(target)) {
          counter.dataset.counterState = "complete";
          return;
        }

        counter.dataset.counterState = "running";

        window.setTimeout(() => {
          const duration = Math.max(680, target * 70);
          let startTime = 0;

          const step = (now: number) => {
            if (!startTime) {
              startTime = now;
            }

            const progress = Math.min((now - startTime) / duration, 1);
            const nextValue = Math.round(easeOutCubic(progress) * target);

            counter.textContent = String(nextValue);

            if (progress < 1) {
              window.requestAnimationFrame(step);
              return;
            }

            finalizeCounter(counter);
          };

          window.requestAnimationFrame(step);
        }, delayMs);
      };

      if (prefersReducedMotion() || !("IntersectionObserver" in window)) {
        counters.forEach(finalizeCounter);
        return;
      }

      counters.forEach((counter) => {
        counter.textContent = "0";
        counter.dataset.counterState = "pending";
      });

      const observer = new IntersectionObserver(
        (entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) {
            return;
          }

          counters.forEach((counter, index) => {
            animateCounter(counter, index * 120);
          });
          observer.disconnect();
        },
        {
          threshold: 0.35,
          rootMargin: "0px 0px -12% 0px",
        },
      );

      observer.observe(section);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initProofCounters, {
      once: true,
    });
  } else {
    initProofCounters();
  }

  document.addEventListener("astro:page-load", initProofCounters);
</script>

<style>
  .site-proof {
    padding: var(--space-5xl) var(--site-gutter);
    background: var(--site-surface-default);
    border-top: 1px solid var(--site-border-default);
    border-bottom: 1px solid var(--site-border-default);
  }

  .site-proof__inner {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
  }

  .site-proof__header {
    max-width: 42rem;
  }

  .site-proof__grid {
    display: grid;
    gap: var(--space-lg);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-proof__item {
    position: relative;
    min-height: 100%;
    gap: var(--space-lg);
    padding: clamp(var(--space-lg), 2vw, var(--space-2xl));
    background: var(--site-surface-elevated);
    border: 1px solid var(--color-line);
    transition: border-color var(--transition-fast);
  }

  .site-proof__item:hover {
    border-color: var(--site-proof-accent);
  }

  .site-proof__item--total {
    --site-proof-accent: var(--color-secondary);
  }

  .site-proof__item--construction {
    --site-proof-accent: var(--color-accent);
  }

  .site-proof__item--ai {
    --site-proof-accent: var(--color-primary);
  }

  .site-proof__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .site-proof__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-md);
    background: var(--site-surface-default);
    color: var(--site-proof-accent);
    border: 1px solid var(--color-line);
    flex-shrink: 0;
  }

  .site-proof__content {
    display: grid;
    gap: var(--space-xs);
  }

  .site-proof__label {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-proof__value {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.18em;
    margin: 0;
    color: var(--color-ink);
    line-height: 0.95;
  }

  .site-proof__value-prefix,
  .site-proof__value-suffix {
    font-size: clamp(var(--text-sm), 0.85rem + 0.45vw, var(--text-lg));
    font-weight: 600;
    line-height: 1.2;
    color: var(--color-text-secondary);
  }

  .site-proof__value-number {
    min-width: 1ch;
    font-size: clamp(var(--text-4xl), 3rem + 2vw, var(--text-6xl));
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--site-proof-accent);
    font-variant-numeric: tabular-nums;
  }

  .site-proof__item--total .site-proof__value-number {
    font-size: clamp(var(--text-5xl), 3rem + 3vw, var(--text-7xl));
  }

  .site-proof__detail {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
  }

  .site-proof__support {
    display: grid;
    gap: var(--space-2xs);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: var(--site-surface-default);
  }

  .site-proof__support-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-proof__support-value {
    font-size: var(--text-md);
    line-height: 1.35;
    color: var(--color-text);
  }

  .site-proof__meta {
    margin: auto 0 0;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--color-line);
    font-size: var(--text-sm);
    line-height: var(--line-height-body);
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .site-proof__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .site-proof__item--total {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1024px) {
    .site-proof__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      align-items: stretch;
    }

    .site-proof__item--total {
      grid-column: span 2;
    }
  }
</style>
