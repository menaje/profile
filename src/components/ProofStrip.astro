---
import type { PublicCareerSummary } from "../lib/public-profile";

interface Props {
  careerSummary: PublicCareerSummary;
}

const { careerSummary } = Astro.props;

const metrics = [
  { value: careerSummary.totalCareer.label, label: "총 경력" },
  { value: careerSummary.constructionCm.label, label: "건설 CM" },
  { value: careerSummary.aiIt.label, label: "AI / IT" },
];
---

<section class="site-proof" aria-labelledby="proof-heading">
  <div class="site-proof__inner">
    <h2 id="proof-heading" class="sr-only">경력 요약</h2>
    <dl class="site-proof__grid">
      {
        metrics.map((m) => (
          <div class="site-proof__item">
            <dt class="site-proof__label">{m.label}</dt>
            <dd class="site-proof__value">{m.value}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .site-proof {
    padding: var(--space-3xl) var(--site-gutter);
    background: var(--color-bg-surface);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }

  .site-proof__inner {
    max-width: var(--site-content-max-width);
    margin: 0 auto;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-proof__grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: 1fr;
    margin: 0;
  }

  .site-proof__item {
    text-align: center;
  }

  .site-proof__value {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-accent);
    margin: 0;
  }

  .site-proof__label {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2xs);
  }

  @media (min-width: 768px) {
    .site-proof__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .site-proof__value {
      font-size: var(--text-3xl);
    }
  }
</style>
