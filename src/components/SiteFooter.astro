---
import { getPublicProfile } from "../lib/public-profile";

const navItems = [
  { label: "소개", href: "/about" },
  { label: "프로젝트", href: "/projects" },
  { label: "이력서", href: "/resume" },
  { label: "블로그", href: "/blog" },
  { label: "연락처", href: "/contact" },
];

const profile = getPublicProfile();
const { github, linkedin } = profile.profile.contacts;
const { name, positioningTitle } = profile.profile;
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a href="/" class="site-footer__brand-link">
        <span class="site-footer__name">{name.ko}</span>
        <span class="site-footer__tagline">{positioningTitle}</span>
      </a>
      <p class="site-footer__copyright">&copy; {currentYear} {name.ko}</p>
    </div>

    <nav class="site-footer__nav" aria-label="푸터 내비게이션">
      <p class="site-footer__label">둘러보기</p>
      <ul class="site-footer__nav-list">
        {
          navItems.map((item) => (
            <li>
              <a href={item.href} class="site-footer__nav-link">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-footer__social">
      <p class="site-footer__label">소셜</p>
      <div class="site-footer__social-links">
        <a
          href={github.url}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__social-link site-button site-button--ghost site-button--quiet"
          aria-label="GitHub"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </a>
        <a
          href={linkedin.url}
          target="_blank"
          rel="noopener noreferrer"
          class="site-footer__social-link site-button site-button--ghost site-button--quiet"
          aria-label="LinkedIn"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    padding: var(--space-4xl) var(--site-gutter) var(--space-3xl);
    border-top: 1px solid var(--site-border-default);
    background: color-mix(
      in srgb,
      var(--site-footer-bg) 92%,
      var(--color-paper)
    );
  }

  .site-footer__inner {
    max-width: var(--site-max-width);
    margin: 0 auto;
    display: grid;
    gap: var(--space-2xl);
  }

  .site-footer__brand,
  .site-footer__nav,
  .site-footer__social {
    display: grid;
    gap: var(--space-sm);
  }

  .site-footer__brand-link {
    display: grid;
    gap: var(--space-2xs);
    width: fit-content;
    text-decoration: none;
  }

  .site-footer__name {
    color: var(--color-ink);
    font-size: clamp(var(--text-xl), 3vw, var(--text-2xl));
    font-weight: 700;
    line-height: var(--line-height-tight);
    letter-spacing: -0.03em;
  }

  .site-footer__tagline {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--line-height-body);
  }

  .site-footer__label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .site-footer__nav-list {
    display: grid;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-footer__nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    width: fit-content;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition:
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .site-footer__nav-link:hover {
    color: var(--color-primary);
    transform: var(--hover-lift);
  }

  .site-footer__social-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .site-footer__social-link {
    width: 44px;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    border-radius: var(--radius-pill);
  }

  .site-footer__copyright {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin: 0;
  }

  @media (min-width: 1024px) {
    .site-footer__inner {
      grid-template-columns: minmax(0, 1.5fr) minmax(10rem, 0.75fr) auto;
      align-items: start;
    }
  }
</style>
