---
import { getAbsoluteLocaleUrl } from "astro:i18n";
import {
  DEFAULT_LOCALE,
  getOgLocale,
  getAlternateLocales,
  getIndexableLocalesForPath,
} from "../lib/i18n";
import { serializeStructuredData, type StructuredDataInput } from "../lib/structured-data";
import { ensureBasePath, withBase } from "../lib/site";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  structuredData?: StructuredDataInput;
}

const currentLocale = Astro.currentLocale ?? DEFAULT_LOCALE;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const pathWithoutBase = Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length) || "/"
  : Astro.url.pathname;
const pathWithoutLocale = pathWithoutBase.replace(/^\/en(\/|$)/, "/");

const {
  title,
  description,
  canonicalUrl = Astro.site
    ? new URL(ensureBasePath(Astro.url.pathname), Astro.site).href
    : Astro.url.href,
  ogImage,
  ogType = "website",
  noindex = false,
  structuredData,
} = Astro.props;

const indexableLocales = getIndexableLocalesForPath(pathWithoutLocale);
const alternateLocales = getAlternateLocales(currentLocale).filter((locale) =>
  indexableLocales.includes(locale),
);
const hreflangEntries = indexableLocales.map((locale) => ({
  locale,
  href: getAbsoluteLocaleUrl(locale, pathWithoutLocale),
}));
const shouldExposeAlternates = !noindex && indexableLocales.length > 1;
const rssUrl = Astro.site ? new URL(withBase("/rss.xml"), Astro.site).href : undefined;
const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
{!noindex && <meta name="robots" content="index,follow,max-image-preview:large" />}
{
  shouldExposeAlternates &&
    hreflangEntries.map(({ locale, href }) => (
      <link rel="alternate" hreflang={locale} href={href} />
    ))
}
{
  shouldExposeAlternates && (
    <link
      rel="alternate"
      hreflang="x-default"
      href={getAbsoluteLocaleUrl(DEFAULT_LOCALE, pathWithoutLocale)}
    />
  )
}
{
  !noindex && rssUrl && (
    <link rel="alternate" type="application/rss+xml" title="김성식 블로그 RSS" href={rssUrl} />
  )
}
{
  structuredDataItems.map((item) => (
    <script is:inline type="application/ld+json" set:html={serializeStructuredData(item)} />
  ))
}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content={getOgLocale(currentLocale)} />
{
  shouldExposeAlternates &&
    alternateLocales.map((locale) => (
      <meta property="og:locale:alternate" content={getOgLocale(locale)} />
    ))
}
{ogImage && <meta property="og:image" content={ogImage} />}
{noindex && <meta name="robots" content="noindex,nofollow" />}
