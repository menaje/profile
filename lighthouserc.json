{
  "ci": {
    "collect": {
      "startServerCommand": "node scripts/lhci-serve.mjs",
      "startServerReadyPattern": "LHCI server ready",
      "url": [
        "http://127.0.0.1:4173/profile/",
        "http://127.0.0.1:4173/profile/about/",
        "http://127.0.0.1:4173/profile/projects/",
        "http://127.0.0.1:4173/profile/blog/",
        "http://127.0.0.1:4173/profile/resume/"
      ],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
